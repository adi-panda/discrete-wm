{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013moXB5ybCuZ7MEKE9WXbPB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LS3Kpi8DHQKMMvsoi7S6RP","name":"Write","input":{"file_path":"/root/research/discrete_wm/evaluate.py","content":"\"\"\"\nEvaluation script for the discrete diffusion world model.\n\nComputes: PSNR, SSIM, LPIPS, inference speed, action controllability.\n\"\"\"\n\nimport argparse\nimport math\nimport os\nimport time\n\nimport numpy as np\nimport torch\nimport torch.nn.functional as F\nfrom torch.utils.data import DataLoader\nfrom tqdm import tqdm\nimport imageio\n\nfrom models.discrete_diffusion import DiscreteWorldModel, detokenize_frames\nfrom utils import AtariFramePairDataset\n\n\ndef compute_psnr_batch(pred, target):\n    \"\"\"PSNR between uint8 image batches. pred, target: [B, H, W, C]\"\"\"\n    mse = ((pred.float() - target.float()) ** 2).mean(dim=(1, 2, 3))\n    psnr = 10 * torch.log10(255.0 ** 2 / (mse + 1e-8))\n    return psnr\n\n\ndef compute_ssim_batch(pred, target):\n    \"\"\"Simplified SSIM for uint8 images. pred, target: [B, C, H, W] float.\"\"\"\n    C1 = (0.01 * 255) ** 2\n    C2 = (0.03 * 255) ** 2\n\n    pred = pred.float()\n    target = target.float()\n\n    mu_p = F.avg_pool2d(pred, 8, stride=8)\n    mu_t = F.avg_pool2d(target, 8, stride=8)\n\n    mu_p_sq = mu_p ** 2\n    mu_t_sq = mu_t ** 2\n    mu_pt = mu_p * mu_t\n\n    sigma_p_sq = F.avg_pool2d(pred ** 2, 8, stride=8) - mu_p_sq\n    sigma_t_sq = F.avg_pool2d(target ** 2, 8, stride=8) - mu_t_sq\n    sigma_pt = F.avg_pool2d(pred * target, 8, stride=8) - mu_pt\n\n    ssim = ((2 * mu_pt + C1) * (2 * sigma_pt + C2)) / \\\n           ((mu_p_sq + mu_t_sq + C1) * (sigma_p_sq + sigma_t_sq + C2))\n\n    return ssim.mean(dim=(1, 2, 3))\n\n\n@torch.no_grad()\ndef evaluate_quality(model, dataset, device, num_bins, num_samples=1000,\n                     gen_steps_list=[4, 8, 16, 32], temperature=0.9):\n    \"\"\"Evaluate prediction quality at different denoising step counts.\"\"\"\n    model.eval()\n\n    results = {}\n\n    for gen_steps in gen_steps_list:\n        psnr_list = []\n        ssim_list = []\n\n        # Process in mini-batches\n        batch_size = 32\n        indices = list(range(0, min(num_samples * 5, len(dataset)), 5))[:num_samples]\n\n        for i in tqdm(range(0, len(indices), batch_size),\n                      desc=f\"Eval (steps={gen_steps})\"):\n            batch_indices = indices[i:i + batch_size]\n            prev_tokens_list = []\n            actions_list = []\n            gt_tokens_list = []\n\n            for idx in batch_indices:\n                pt, a, nt = dataset[idx]\n                prev_tokens_list.append(pt)\n                actions_list.append(a)\n                gt_tokens_list.append(nt)\n\n            prev_tokens = torch.stack(prev_tokens_list).to(device)\n            actions = torch.stack(actions_list).to(device)\n            gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n            # Generate\n            pred_tokens = model.generate(\n                prev_tokens, actions, num_steps=gen_steps,\n                temperature=temperature, device=device\n            )\n\n            # Detokenize to images\n            pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins)  # [B, H, W, C]\n            gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins)\n\n            # PSNR\n            psnr = compute_psnr_batch(pred_frames, gt_frames)\n            psnr_list.extend(psnr.cpu().tolist())\n\n            # SSIM (needs BCHW format)\n            pred_bchw = pred_frames.permute(0, 3, 1, 2).float()\n            gt_bchw = gt_frames.permute(0, 3, 1, 2).float()\n            ssim = compute_ssim_batch(pred_bchw, gt_bchw)\n            ssim_list.extend(ssim.cpu().tolist())\n\n        results[gen_steps] = {\n            'psnr_mean': np.mean(psnr_list),\n            'psnr_std': np.std(psnr_list),\n            'ssim_mean': np.mean(ssim_list),\n            'ssim_std': np.std(ssim_list),\n        }\n\n        print(f\"  Steps={gen_steps}: PSNR={results[gen_steps]['psnr_mean']:.2f}±{results[gen_steps]['psnr_std']:.2f}, \"\n              f\"SSIM={results[gen_steps]['ssim_mean']:.4f}±{results[gen_steps]['ssim_std']:.4f}\")\n\n    return results\n\n\n@torch.no_grad()\ndef evaluate_lpips(model, dataset, device, num_bins, num_samples=500, gen_steps=8, temperature=0.9):\n    \"\"\"Evaluate LPIPS (learned perceptual similarity).\"\"\"\n    import lpips\n\n    model.eval()\n    loss_fn = lpips.LPIPS(net='alex').to(device)\n\n    lpips_list = []\n    batch_size = 16\n    indices = list(range(0, min(num_samples * 5, len(dataset)), 5))[:num_samples]\n\n    for i in tqdm(range(0, len(indices), batch_size), desc=\"LPIPS\"):\n        batch_indices = indices[i:i + batch_size]\n        prev_tokens_list = []\n        actions_list = []\n        gt_tokens_list = []\n\n        for idx in batch_indices:\n            pt, a, nt = dataset[idx]\n            prev_tokens_list.append(pt)\n            actions_list.append(a)\n            gt_tokens_list.append(nt)\n\n        prev_tokens = torch.stack(prev_tokens_list).to(device)\n        actions = torch.stack(actions_list).to(device)\n        gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n        pred_tokens = model.generate(\n            prev_tokens, actions, num_steps=gen_steps,\n            temperature=temperature, device=device\n        )\n\n        # LPIPS expects [-1, 1] range, BCHW format\n        pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins).float().permute(0, 3, 1, 2) / 127.5 - 1.0\n        gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins).float().permute(0, 3, 1, 2) / 127.5 - 1.0\n\n        lpips_val = loss_fn(pred_frames, gt_frames)\n        lpips_list.extend(lpips_val.squeeze().cpu().tolist())\n\n    mean_lpips = np.mean(lpips_list)\n    std_lpips = np.std(lpips_list)\n    print(f\"LPIPS: {mean_lpips:.4f}±{std_lpips:.4f}\")\n    return {'lpips_mean': mean_lpips, 'lpips_std': std_lpips}\n\n\n@torch.no_grad()\ndef evaluate_speed(model, dataset, device, num_bins, gen_steps_list=[4, 8, 16, 32]):\n    \"\"\"Measure inference speed (frames per second).\"\"\"\n    model.eval()\n\n    pt, a, nt = dataset[0]\n    prev_tokens = pt.unsqueeze(0).to(device)\n    actions = a.unsqueeze(0).to(device)\n\n    results = {}\n    for gen_steps in gen_steps_list:\n        # Warmup\n        for _ in range(3):\n            model.generate(prev_tokens, actions, num_steps=gen_steps, device=device)\n\n        torch.cuda.synchronize()\n        start = time.time()\n        n_iters = 50\n        for _ in range(n_iters):\n            model.generate(prev_tokens, actions, num_steps=gen_steps, device=device)\n        torch.cuda.synchronize()\n        elapsed = time.time() - start\n\n        fps = n_iters / elapsed\n        ms_per_frame = elapsed / n_iters * 1000\n\n        results[gen_steps] = {'fps': fps, 'ms_per_frame': ms_per_frame}\n        print(f\"  Steps={gen_steps}: {fps:.1f} FPS ({ms_per_frame:.1f} ms/frame)\")\n\n    return results\n\n\n@torch.no_grad()\ndef evaluate_long_horizon(model, dataset, device, num_bins, num_rollouts=10,\n                          rollout_length=50, gen_steps=8, temperature=0.9, save_dir=None):\n    \"\"\"Generate long autoregressive rollouts and measure quality degradation.\"\"\"\n    model.eval()\n\n    if save_dir:\n        os.makedirs(save_dir, exist_ok=True)\n\n    all_psnr_by_step = [[] for _ in range(rollout_length)]\n\n    for r in tqdm(range(num_rollouts), desc=\"Long-horizon rollouts\"):\n        # Get a starting frame and sequence of actions\n        start_idx = r * 100  # Spread out across dataset\n        if start_idx + rollout_length >= len(dataset):\n            start_idx = 0\n\n        pt, a, nt = dataset[start_idx]\n        current_tokens = pt.unsqueeze(0).to(device)\n\n        rollout_frames = []\n        gt_frames_list = []\n\n        for step in range(rollout_length):\n            idx = min(start_idx + step, len(dataset) - 1)\n            _, action, gt_next = dataset[idx]\n            action = action.unsqueeze(0).to(device)\n\n            # Generate next frame\n            pred_tokens = model.generate(\n                current_tokens, action, num_steps=gen_steps,\n                temperature=temperature, device=device\n            )\n\n            # Compute quality vs ground truth\n            pred_frame = detokenize_frames(pred_tokens, num_bins=num_bins)\n            gt_frame = detokenize_frames(gt_next.unsqueeze(0).to(device), num_bins=num_bins)\n\n            psnr = compute_psnr_batch(pred_frame, gt_frame).item()\n            all_psnr_by_step[step].append(psnr)\n\n            rollout_frames.append(pred_frame[0].cpu().numpy())\n            gt_frames_list.append(gt_frame[0].cpu().numpy())\n\n            # Use predicted frame as input for next step (autoregressive)\n            current_tokens = pred_tokens\n\n        # Save rollout as GIF\n        if save_dir and r < 3:\n            rollout_np = np.array(rollout_frames)\n            imageio.mimsave(\n                os.path.join(save_dir, f'rollout_{r:02d}.gif'),\n                rollout_np, fps=10\n            )\n            # Also save side-by-side\n            comparison = []\n            for s in range(rollout_length):\n                frame = np.concatenate([gt_frames_list[s], rollout_frames[s]], axis=1)\n                comparison.append(frame)\n            imageio.mimsave(\n                os.path.join(save_dir, f'rollout_{r:02d}_comparison.gif'),\n                comparison, fps=10\n            )\n\n    # Aggregate\n    psnr_by_step = [np.mean(x) if x else 0.0 for x in all_psnr_by_step]\n    print(f\"Long-horizon PSNR: step 1={psnr_by_step[0]:.2f}, \"\n          f\"step 10={psnr_by_step[9]:.2f}, step 50={psnr_by_step[-1]:.2f}\")\n\n    return psnr_by_step\n\n\n@torch.no_grad()\ndef evaluate_action_controllability(model, dataset, device, num_bins,\n                                     num_samples=50, gen_steps=8, save_dir=None):\n    \"\"\"Test if different actions produce different outputs from same starting frame.\"\"\"\n    model.eval()\n\n    if save_dir:\n        os.makedirs(save_dir, exist_ok=True)\n\n    # Get number of actions from the model\n    n_actions = model.action_embed[0].num_embeddings\n\n    diffs = []\n\n    for i in tqdm(range(num_samples), desc=\"Action controllability\"):\n        pt, _, _ = dataset[i * 10 % len(dataset)]\n        prev_tokens = pt.unsqueeze(0).to(device)\n\n        # Generate with each action\n        action_frames = []\n        for a in range(n_actions):\n            action = torch.tensor([a], device=device)\n            pred_tokens = model.generate(\n                prev_tokens, action, num_steps=gen_steps,\n                temperature=0.9, device=device\n            )\n            pred_frame = detokenize_frames(pred_tokens, num_bins=num_bins)[0].float()\n            action_frames.append(pred_frame)\n\n        # Compute pairwise differences\n        for a1 in range(n_actions):\n            for a2 in range(a1 + 1, n_actions):\n                diff = (action_frames[a1] - action_frames[a2]).abs().mean().item()\n                diffs.append(diff)\n\n        # Save first few\n        if save_dir and i < 5:\n            prev_frame = detokenize_frames(prev_tokens, num_bins=num_bins)[0].cpu().numpy()\n            row = [prev_frame]\n            for af in action_frames:\n                row.append(af.cpu().numpy().astype(np.uint8))\n            grid = np.concatenate(row, axis=1)\n            imageio.imwrite(os.path.join(save_dir, f'action_ctrl_{i:02d}.png'), grid)\n\n    mean_diff = np.mean(diffs)\n    print(f\"Action controllability: mean pairwise pixel diff = {mean_diff:.2f}\")\n    return mean_diff\n\n\ndef main(args):\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\n    # Load dataset\n    dataset = AtariFramePairDataset(args.data, num_bins=args.num_bins)\n\n    # Load model\n    ckpt = torch.load(args.checkpoint, map_location=device)\n    model_args = ckpt.get('args', {})\n\n    model = DiscreteWorldModel(\n        vocab_size=args.num_bins,\n        num_channels=3,\n        spatial_h=64,\n        spatial_w=64,\n        d_model=model_args.get('d_model', 384),\n        n_layers=model_args.get('n_layers', 8),\n        n_heads=model_args.get('n_heads', 6),\n        n_actions=dataset.num_actions,\n        cond_dim=model_args.get('d_model', 384),\n    ).to(device)\n\n    model.load_state_dict(ckpt['model'])\n    model.eval()\n\n    num_params = sum(p.numel() for p in model.parameters())\n    print(f\"Loaded model: {num_params / 1e6:.1f}M params, step {ckpt.get('step', '?')}\")\n\n    results = {}\n\n    # 1. Quality metrics at different denoising steps\n    print(\"\\n=== Quality Metrics ===\")\n    quality = evaluate_quality(\n        model, dataset, device, args.num_bins,\n        num_samples=args.num_quality_samples,\n        gen_steps_list=[4, 8, 16, 32],\n    )\n    results['quality'] = quality\n\n    # 2. LPIPS\n    print(\"\\n=== LPIPS ===\")\n    lpips_result = evaluate_lpips(\n        model, dataset, device, args.num_bins,\n        num_samples=min(args.num_quality_samples, 500),\n        gen_steps=8,\n    )\n    results['lpips'] = lpips_result\n\n    # 3. Inference speed\n    print(\"\\n=== Inference Speed ===\")\n    speed = evaluate_speed(model, dataset, device, args.num_bins)\n    results['speed'] = speed\n\n    # 4. Long-horizon rollouts\n    print(\"\\n=== Long-horizon Rollouts ===\")\n    psnr_by_step = evaluate_long_horizon(\n        model, dataset, device, args.num_bins,\n        num_rollouts=10, rollout_length=50, gen_steps=8,\n        save_dir=os.path.join(args.output_dir, 'rollouts'),\n    )\n    results['long_horizon_psnr'] = psnr_by_step\n\n    # 5. Action controllability\n    print(\"\\n=== Action Controllability ===\")\n    action_diff = evaluate_action_controllability(\n        model, dataset, device, args.num_bins,\n        num_samples=50, gen_steps=8,\n        save_dir=os.path.join(args.output_dir, 'action_ctrl'),\n    )\n    results['action_controllability'] = action_diff\n\n    # Save results\n    import json\n    results_path = os.path.join(args.output_dir, 'eval_results.json')\n    # Convert numpy types\n    def convert(obj):\n        if isinstance(obj, (np.integer,)):\n            return int(obj)\n        if isinstance(obj, (np.floating,)):\n            return float(obj)\n        if isinstance(obj, np.ndarray):\n            return obj.tolist()\n        return obj\n\n    with open(results_path, 'w') as f:\n        json.dump(results, f, indent=2, default=convert)\n\n    print(f\"\\nResults saved to {results_path}\")\n    return results\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--checkpoint\", required=True)\n    parser.add_argument(\"--data\", default=\"/root/research/discrete_wm/data/atari_data.npz\")\n    parser.add_argument(\"--num-bins\", type=int, default=64)\n    parser.add_argument(\"--num-quality-samples\", type=int, default=1000)\n    parser.add_argument(\"--output-dir\", default=\"/root/research/figures/eval\")\n\n    args = parser.parse_args()\n    os.makedirs(args.output_dir, exist_ok=True)\n\n    main(args)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3873,"cache_read_input_tokens":40109,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3873},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"84769e90-eb21-4a43-a456-19171e8efa68"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LS3Kpi8DHQKMMvsoi7S6RP","type":"tool_result","content":"File created successfully at: /root/research/discrete_wm/evaluate.py"}]},"parent_tool_use_id":null,"session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"0048174c-d5c2-4030-acb0-bad3f126c855","timestamp":"2026-04-05T08:34:30.003Z","tool_use_result":{"type":"create","filePath":"/root/research/discrete_wm/evaluate.py","content":"\"\"\"\nEvaluation script for the discrete diffusion world model.\n\nComputes: PSNR, SSIM, LPIPS, inference speed, action controllability.\n\"\"\"\n\nimport argparse\nimport math\nimport os\nimport time\n\nimport numpy as np\nimport torch\nimport torch.nn.functional as F\nfrom torch.utils.data import DataLoader\nfrom tqdm import tqdm\nimport imageio\n\nfrom models.discrete_diffusion import DiscreteWorldModel, detokenize_frames\nfrom utils import AtariFramePairDataset\n\n\ndef compute_psnr_batch(pred, target):\n    \"\"\"PSNR between uint8 image batches. pred, target: [B, H, W, C]\"\"\"\n    mse = ((pred.float() - target.float()) ** 2).mean(dim=(1, 2, 3))\n    psnr = 10 * torch.log10(255.0 ** 2 / (mse + 1e-8))\n    return psnr\n\n\ndef compute_ssim_batch(pred, target):\n    \"\"\"Simplified SSIM for uint8 images. pred, target: [B, C, H, W] float.\"\"\"\n    C1 = (0.01 * 255) ** 2\n    C2 = (0.03 * 255) ** 2\n\n    pred = pred.float()\n    target = target.float()\n\n    mu_p = F.avg_pool2d(pred, 8, stride=8)\n    mu_t = F.avg_pool2d(target, 8, stride=8)\n\n    mu_p_sq = mu_p ** 2\n    mu_t_sq = mu_t ** 2\n    mu_pt = mu_p * mu_t\n\n    sigma_p_sq = F.avg_pool2d(pred ** 2, 8, stride=8) - mu_p_sq\n    sigma_t_sq = F.avg_pool2d(target ** 2, 8, stride=8) - mu_t_sq\n    sigma_pt = F.avg_pool2d(pred * target, 8, stride=8) - mu_pt\n\n    ssim = ((2 * mu_pt + C1) * (2 * sigma_pt + C2)) / \\\n           ((mu_p_sq + mu_t_sq + C1) * (sigma_p_sq + sigma_t_sq + C2))\n\n    return ssim.mean(dim=(1, 2, 3))\n\n\n@torch.no_grad()\ndef evaluate_quality(model, dataset, device, num_bins, num_samples=1000,\n                     gen_steps_list=[4, 8, 16, 32], temperature=0.9):\n    \"\"\"Evaluate prediction quality at different denoising step counts.\"\"\"\n    model.eval()\n\n    results = {}\n\n    for gen_steps in gen_steps_list:\n        psnr_list = []\n        ssim_list = []\n\n        # Process in mini-batches\n        batch_size = 32\n        indices = list(range(0, min(num_samples * 5, len(dataset)), 5))[:num_samples]\n\n        for i in tqdm(range(0, len(indices), batch_size),\n                      desc=f\"Eval (steps={gen_steps})\"):\n            batch_indices = indices[i:i + batch_size]\n            prev_tokens_list = []\n            actions_list = []\n            gt_tokens_list = []\n\n            for idx in batch_indices:\n                pt, a, nt = dataset[idx]\n                prev_tokens_list.append(pt)\n                actions_list.append(a)\n                gt_tokens_list.append(nt)\n\n            prev_tokens = torch.stack(prev_tokens_list).to(device)\n            actions = torch.stack(actions_list).to(device)\n            gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n            # Generate\n            pred_tokens = model.generate(\n                prev_tokens, actions, num_steps=gen_steps,\n                temperature=temperature, device=device\n            )\n\n            # Detokenize to images\n            pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins)  # [B, H, W, C]\n            gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins)\n\n            # PSNR\n            psnr = compute_psnr_batch(pred_frames, gt_frames)\n            psnr_list.extend(psnr.cpu().tolist())\n\n            # SSIM (needs BCHW format)\n            pred_bchw = pred_frames.permute(0, 3, 1, 2).float()\n            gt_bchw = gt_frames.permute(0, 3, 1, 2).float()\n            ssim = compute_ssim_batch(pred_bchw, gt_bchw)\n            ssim_list.extend(ssim.cpu().tolist())\n\n        results[gen_steps] = {\n            'psnr_mean': np.mean(psnr_list),\n            'psnr_std': np.std(psnr_list),\n            'ssim_mean': np.mean(ssim_list),\n            'ssim_std': np.std(ssim_list),\n        }\n\n        print(f\"  Steps={gen_steps}: PSNR={results[gen_steps]['psnr_mean']:.2f}±{results[gen_steps]['psnr_std']:.2f}, \"\n              f\"SSIM={results[gen_steps]['ssim_mean']:.4f}±{results[gen_steps]['ssim_std']:.4f}\")\n\n    return results\n\n\n@torch.no_grad()\ndef evaluate_lpips(model, dataset, device, num_bins, num_samples=500, gen_steps=8, temperature=0.9):\n    \"\"\"Evaluate LPIPS (learned perceptual similarity).\"\"\"\n    import lpips\n\n    model.eval()\n    loss_fn = lpips.LPIPS(net='alex').to(device)\n\n    lpips_list = []\n    batch_size = 16\n    indices = list(range(0, min(num_samples * 5, len(dataset)), 5))[:num_samples]\n\n    for i in tqdm(range(0, len(indices), batch_size), desc=\"LPIPS\"):\n        batch_indices = indices[i:i + batch_size]\n        prev_tokens_list = []\n        actions_list = []\n        gt_tokens_list = []\n\n        for idx in batch_indices:\n            pt, a, nt = dataset[idx]\n            prev_tokens_list.append(pt)\n            actions_list.append(a)\n            gt_tokens_list.append(nt)\n\n        prev_tokens = torch.stack(prev_tokens_list).to(device)\n        actions = torch.stack(actions_list).to(device)\n        gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n        pred_tokens = model.generate(\n            prev_tokens, actions, num_steps=gen_steps,\n            temperature=temperature, device=device\n        )\n\n        # LPIPS expects [-1, 1] range, BCHW format\n        pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins).float().permute(0, 3, 1, 2) / 127.5 - 1.0\n        gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins).float().permute(0, 3, 1, 2) / 127.5 - 1.0\n\n        lpips_val = loss_fn(pred_frames, gt_frames)\n        lpips_list.extend(lpips_val.squeeze().cpu().tolist())\n\n    mean_lpips = np.mean(lpips_list)\n    std_lpips = np.std(lpips_list)\n    print(f\"LPIPS: {mean_lpips:.4f}±{std_lpips:.4f}\")\n    return {'lpips_mean': mean_lpips, 'lpips_std': std_lpips}\n\n\n@torch.no_grad()\ndef evaluate_speed(model, dataset, device, num_bins, gen_steps_list=[4, 8, 16, 32]):\n    \"\"\"Measure inference speed (frames per second).\"\"\"\n    model.eval()\n\n    pt, a, nt = dataset[0]\n    prev_tokens = pt.unsqueeze(0).to(device)\n    actions = a.unsqueeze(0).to(device)\n\n    results = {}\n    for gen_steps in gen_steps_list:\n        # Warmup\n        for _ in range(3):\n            model.generate(prev_tokens, actions, num_steps=gen_steps, device=device)\n\n        torch.cuda.synchronize()\n        start = time.time()\n        n_iters = 50\n        for _ in range(n_iters):\n            model.generate(prev_tokens, actions, num_steps=gen_steps, device=device)\n        torch.cuda.synchronize()\n        elapsed = time.time() - start\n\n        fps = n_iters / elapsed\n        ms_per_frame = elapsed / n_iters * 1000\n\n        results[gen_steps] = {'fps': fps, 'ms_per_frame': ms_per_frame}\n        print(f\"  Steps={gen_steps}: {fps:.1f} FPS ({ms_per_frame:.1f} ms/frame)\")\n\n    return results\n\n\n@torch.no_grad()\ndef evaluate_long_horizon(model, dataset, device, num_bins, num_rollouts=10,\n                          rollout_length=50, gen_steps=8, temperature=0.9, save_dir=None):\n    \"\"\"Generate long autoregressive rollouts and measure quality degradation.\"\"\"\n    model.eval()\n\n    if save_dir:\n        os.makedirs(save_dir, exist_ok=True)\n\n    all_psnr_by_step = [[] for _ in range(rollout_length)]\n\n    for r in tqdm(range(num_rollouts), desc=\"Long-horizon rollouts\"):\n        # Get a starting frame and sequence of actions\n        start_idx = r * 100  # Spread out across dataset\n        if start_idx + rollout_length >= len(dataset):\n            start_idx = 0\n\n        pt, a, nt = dataset[start_idx]\n        current_tokens = pt.unsqueeze(0).to(device)\n\n        rollout_frames = []\n        gt_frames_list = []\n\n        for step in range(rollout_length):\n            idx = min(start_idx + step, len(dataset) - 1)\n            _, action, gt_next = dataset[idx]\n            action = action.unsqueeze(0).to(device)\n\n            # Generate next frame\n            pred_tokens = model.generate(\n                current_tokens, action, num_steps=gen_steps,\n                temperature=temperature, device=device\n            )\n\n            # Compute quality vs ground truth\n            pred_frame = detokenize_frames(pred_tokens, num_bins=num_bins)\n            gt_frame = detokenize_frames(gt_next.unsqueeze(0).to(device), num_bins=num_bins)\n\n            psnr = compute_psnr_batch(pred_frame, gt_frame).item()\n            all_psnr_by_step[step].append(psnr)\n\n            rollout_frames.append(pred_frame[0].cpu().numpy())\n            gt_frames_list.append(gt_frame[0].cpu().numpy())\n\n            # Use predicted frame as input for next step (autoregressive)\n            current_tokens = pred_tokens\n\n        # Save rollout as GIF\n        if save_dir and r < 3:\n            rollout_np = np.array(rollout_frames)\n            imageio.mimsave(\n                os.path.join(save_dir, f'rollout_{r:02d}.gif'),\n                rollout_np, fps=10\n            )\n            # Also save side-by-side\n            comparison = []\n            for s in range(rollout_length):\n                frame = np.concatenate([gt_frames_list[s], rollout_frames[s]], axis=1)\n                comparison.append(frame)\n            imageio.mimsave(\n                os.path.join(save_dir, f'rollout_{r:02d}_comparison.gif'),\n                comparison, fps=10\n            )\n\n    # Aggregate\n    psnr_by_step = [np.mean(x) if x else 0.0 for x in all_psnr_by_step]\n    print(f\"Long-horizon PSNR: step 1={psnr_by_step[0]:.2f}, \"\n          f\"step 10={psnr_by_step[9]:.2f}, step 50={psnr_by_step[-1]:.2f}\")\n\n    return psnr_by_step\n\n\n@torch.no_grad()\ndef evaluate_action_controllability(model, dataset, device, num_bins,\n                                     num_samples=50, gen_steps=8, save_dir=None):\n    \"\"\"Test if different actions produce different outputs from same starting frame.\"\"\"\n    model.eval()\n\n    if save_dir:\n        os.makedirs(save_dir, exist_ok=True)\n\n    # Get number of actions from the model\n    n_actions = model.action_embed[0].num_embeddings\n\n    diffs = []\n\n    for i in tqdm(range(num_samples), desc=\"Action controllability\"):\n        pt, _, _ = dataset[i * 10 % len(dataset)]\n        prev_tokens = pt.unsqueeze(0).to(device)\n\n        # Generate with each action\n        action_frames = []\n        for a in range(n_actions):\n            action = torch.tensor([a], device=device)\n            pred_tokens = model.generate(\n                prev_tokens, action, num_steps=gen_steps,\n                temperature=0.9, device=device\n            )\n            pred_frame = detokenize_frames(pred_tokens, num_bins=num_bins)[0].float()\n            action_frames.append(pred_frame)\n\n        # Compute pairwise differences\n        for a1 in range(n_actions):\n            for a2 in range(a1 + 1, n_actions):\n                diff = (action_frames[a1] - action_frames[a2]).abs().mean().item()\n                diffs.append(diff)\n\n        # Save first few\n        if save_dir and i < 5:\n            prev_frame = detokenize_frames(prev_tokens, num_bins=num_bins)[0].cpu().numpy()\n            row = [prev_frame]\n            for af in action_frames:\n                row.append(af.cpu().numpy().astype(np.uint8))\n            grid = np.concatenate(row, axis=1)\n            imageio.imwrite(os.path.join(save_dir, f'action_ctrl_{i:02d}.png'), grid)\n\n    mean_diff = np.mean(diffs)\n    print(f\"Action controllability: mean pairwise pixel diff = {mean_diff:.2f}\")\n    return mean_diff\n\n\ndef main(args):\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\n    # Load dataset\n    dataset = AtariFramePairDataset(args.data, num_bins=args.num_bins)\n\n    # Load model\n    ckpt = torch.load(args.checkpoint, map_location=device)\n    model_args = ckpt.get('args', {})\n\n    model = DiscreteWorldModel(\n        vocab_size=args.num_bins,\n        num_channels=3,\n        spatial_h=64,\n        spatial_w=64,\n        d_model=model_args.get('d_model', 384),\n        n_layers=model_args.get('n_layers', 8),\n        n_heads=model_args.get('n_heads', 6),\n        n_actions=dataset.num_actions,\n        cond_dim=model_args.get('d_model', 384),\n    ).to(device)\n\n    model.load_state_dict(ckpt['model'])\n    model.eval()\n\n    num_params = sum(p.numel() for p in model.parameters())\n    print(f\"Loaded model: {num_params / 1e6:.1f}M params, step {ckpt.get('step', '?')}\")\n\n    results = {}\n\n    # 1. Quality metrics at different denoising steps\n    print(\"\\n=== Quality Metrics ===\")\n    quality = evaluate_quality(\n        model, dataset, device, args.num_bins,\n        num_samples=args.num_quality_samples,\n        gen_steps_list=[4, 8, 16, 32],\n    )\n    results['quality'] = quality\n\n    # 2. LPIPS\n    print(\"\\n=== LPIPS ===\")\n    lpips_result = evaluate_lpips(\n        model, dataset, device, args.num_bins,\n        num_samples=min(args.num_quality_samples, 500),\n        gen_steps=8,\n    )\n    results['lpips'] = lpips_result\n\n    # 3. Inference speed\n    print(\"\\n=== Inference Speed ===\")\n    speed = evaluate_speed(model, dataset, device, args.num_bins)\n    results['speed'] = speed\n\n    # 4. Long-horizon rollouts\n    print(\"\\n=== Long-horizon Rollouts ===\")\n    psnr_by_step = evaluate_long_horizon(\n        model, dataset, device, args.num_bins,\n        num_rollouts=10, rollout_length=50, gen_steps=8,\n        save_dir=os.path.join(args.output_dir, 'rollouts'),\n    )\n    results['long_horizon_psnr'] = psnr_by_step\n\n    # 5. Action controllability\n    print(\"\\n=== Action Controllability ===\")\n    action_diff = evaluate_action_controllability(\n        model, dataset, device, args.num_bins,\n        num_samples=50, gen_steps=8,\n        save_dir=os.path.join(args.output_dir, 'action_ctrl'),\n    )\n    results['action_controllability'] = action_diff\n\n    # Save results\n    import json\n    results_path = os.path.join(args.output_dir, 'eval_results.json')\n    # Convert numpy types\n    def convert(obj):\n        if isinstance(obj, (np.integer,)):\n            return int(obj)\n        if isinstance(obj, (np.floating,)):\n            return float(obj)\n        if isinstance(obj, np.ndarray):\n            return obj.tolist()\n        return obj\n\n    with open(results_path, 'w') as f:\n        json.dump(results, f, indent=2, default=convert)\n\n    print(f\"\\nResults saved to {results_path}\")\n    return results\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--checkpoint\", required=True)\n    parser.add_argument(\"--data\", default=\"/root/research/discrete_wm/data/atari_data.npz\")\n    parser.add_argument(\"--num-bins\", type=int, default=64)\n    parser.add_argument(\"--num-quality-samples\", type=int, default=1000)\n    parser.add_argument(\"--output-dir\", default=\"/root/research/figures/eval\")\n\n    args = parser.parse_args()\n    os.makedirs(args.output_dir, exist_ok=True)\n\n    main(args)\n","structuredPatch":[],"originalFile":null}}
