{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PAqPYDoHKZ5dm9JV5QT1T5","type":"tool_result","content":"1\tfrom dataclasses import dataclass\n2\tfrom pathlib import Path\n3\tfrom typing import Union\n4\t\n5\timport torch\n6\timport torch.nn as nn\n7\t\n8\tfrom envs import TorchEnv, WorldModelEnv\n9\tfrom models.actor_critic import ActorCritic, ActorCriticConfig, ActorCriticLossConfig\n10\tfrom models.diffusion import Denoiser, DenoiserConfig, SigmaDistributionConfig\n11\tfrom models.rew_end_model import RewEndModel, RewEndModelConfig\n12\tfrom utils import extract_state_dict\n13\t\n14\t\n15\t@dataclass\n16\tclass AgentConfig:\n17\t    denoiser: DenoiserConfig\n18\t    rew_end_model: RewEndModelConfig\n19\t    actor_critic: ActorCriticConfig\n20\t    num_actions: int\n21\t\n22\t    def __post_init__(self) -> None:\n23\t        self.denoiser.inner_model.num_actions = self.num_actions\n24\t        self.rew_end_model.num_actions = self.num_actions\n25\t        self.actor_critic.num_actions = self.num_actions\n26\t\n27\t\n28\tclass Agent(nn.Module):\n29\t    def __init__(self, cfg: AgentConfig) -> None:\n30\t        super().__init__()\n31\t        self.denoiser = Denoiser(cfg.denoiser)\n32\t        self.rew_end_model = RewEndModel(cfg.rew_end_model)\n33\t        self.actor_critic = ActorCritic(cfg.actor_critic)\n34\t\n35\t    @property\n36\t    def device(self):\n37\t        return self.denoiser.device\n38\t\n39\t    def setup_training(\n40\t        self,\n41\t        sigma_distribution_cfg: SigmaDistributionConfig,\n42\t        actor_critic_loss_cfg: ActorCriticLossConfig,\n43\t        rl_env: Union[TorchEnv, WorldModelEnv],\n44\t    ) -> None:\n45\t        self.denoiser.setup_training(sigma_distribution_cfg)\n46\t        self.actor_critic.setup_training(rl_env, actor_critic_loss_cfg)\n47\t\n48\t    def load(\n49\t        self,\n50\t        path_to_ckpt: Path,\n51\t        load_denoiser: bool = True,\n52\t        load_rew_end_model: bool = True,\n53\t        load_actor_critic: bool = True,\n54\t    ) -> None:\n55\t        sd = torch.load(Path(path_to_ckpt), map_location=self.device)\n56\t        sd = {k: extract_state_dict(sd, k) for k in (\"denoiser\", \"rew_end_model\", \"actor_critic\")}\n57\t        if load_denoiser:\n58\t            self.denoiser.load_state_dict(sd[\"denoiser\"])\n59\t        if load_rew_end_model:\n60\t            self.rew_end_model.load_state_dict(sd[\"rew_end_model\"])\n61\t        if load_actor_critic:\n62\t            self.actor_critic.load_state_dict(sd[\"actor_critic\"])\n63\t"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"b7b54025-f61b-4f90-8086-10029080abbc","timestamp":"2026-04-05T08:29:42.386Z"}
