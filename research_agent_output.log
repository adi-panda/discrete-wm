{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XpwD4B4FtGvej2wL85dTHr","type":"tool_result","content":"1\tfrom dataclasses import dataclass\n2\tfrom typing import Optional\n3\t\n4\timport torch\n5\tfrom torch import Tensor\n6\timport torch.nn as nn\n7\timport torch.nn.functional as F\n8\t\n9\tfrom data import Batch\n10\tfrom .inner_model import InnerModel, InnerModelConfig\n11\tfrom utils import LossAndLogs\n12\t\n13\t\n14\tdef add_dims(input: Tensor, n: int) -> Tensor:\n15\t    return input.reshape(input.shape + (1,) * (n - input.ndim))\n16\t\n17\t\n18\t@dataclass\n19\tclass Conditioners:\n20\t    c_in: Tensor\n21\t    c_out: Tensor\n22\t    c_skip: Tensor\n23\t    c_noise: Tensor\n24\t\n25\t\n26\t@dataclass\n27\tclass SigmaDistributionConfig:\n28\t    loc: float\n29\t    scale: float\n30\t    sigma_min: float\n31\t    sigma_max: float\n32\t\n33\t\n34\t@dataclass\n35\tclass DenoiserConfig:\n36\t    inner_model: InnerModelConfig\n37\t    sigma_data: float\n38\t    sigma_offset_noise: float\n39\t\n40\t\n41\tclass Denoiser(nn.Module):\n42\t    def __init__(self, cfg: DenoiserConfig) -> None:\n43\t        super().__init__()\n44\t        self.cfg = cfg\n45\t        self.inner_model = InnerModel(cfg.inner_model)\n46\t        self.sample_sigma_training = None\n47\t\n48\t    @property\n49\t    def device(self) -> torch.device:\n50\t        return self.inner_model.noise_emb.weight.device\n51\t\n52\t    def setup_training(self, cfg: SigmaDistributionConfig) -> None:\n53\t        assert self.sample_sigma_training is None\n54\t\n55\t        def sample_sigma(n: int, device: torch.device):\n56\t            s = torch.randn(n, device=device) * cfg.scale + cfg.loc\n57\t            return s.exp().clip(cfg.sigma_min, cfg.sigma_max)\n58\t\n59\t        self.sample_sigma_training = sample_sigma\n60\t    \n61\t    def apply_noise(self, x: Tensor, sigma: Tensor, sigma_offset_noise: float) -> Tensor:\n62\t        b, c, _, _ = x.shape \n63\t        offset_noise = sigma_offset_noise * torch.randn(b, c, 1, 1, device=self.device)\n64\t        return x + offset_noise + torch.randn_like(x) * add_dims(sigma, x.ndim)\n65\t\n66\t    def compute_conditioners(self, sigma: Tensor) -> Conditioners:\n67\t        sigma = (sigma**2 + self.cfg.sigma_offset_noise**2).sqrt()\n68\t        c_in = 1 / (sigma**2 + self.cfg.sigma_data**2).sqrt()\n69\t        c_skip = self.cfg.sigma_data**2 / (sigma**2 + self.cfg.sigma_data**2)\n70\t        c_out = sigma * c_skip.sqrt()\n71\t        c_noise = sigma.log() / 4\n72\t        return Conditioners(*(add_dims(c, n) for c, n in zip((c_in, c_out, c_skip, c_noise), (4, 4, 4, 1, 1))))\n73\t\n74\t    def compute_model_output(self, noisy_next_obs: Tensor, obs: Tensor, act: Tensor, cs: Conditioners) -> Tensor:\n75\t        rescaled_obs = obs / self.cfg.sigma_data\n76\t        rescaled_noise = noisy_next_obs * cs.c_in\n77\t        return self.inner_model(rescaled_noise, cs.c_noise, rescaled_obs, act)\n78\t    \n79\t    @torch.no_grad()\n80\t    def wrap_model_output(self, noisy_next_obs: Tensor, model_output: Tensor, cs: Conditioners) -> Tensor:\n81\t        d = cs.c_skip * noisy_next_obs + cs.c_out * model_output\n82\t        # Quantize to {0, ..., 255}, then back to [-1, 1]\n83\t        d = d.clamp(-1, 1).add(1).div(2).mul(255).byte().div(255).mul(2).sub(1)\n84\t        return d\n85\t    \n86\t    @torch.no_grad()\n87\t    def denoise(self, noisy_next_obs: Tensor, sigma: Tensor, obs: Tensor, act: Tensor) -> Tensor:\n88\t        cs = self.compute_conditioners(sigma)\n89\t        model_output = self.compute_model_output(noisy_next_obs, obs, act, cs)\n90\t        denoised = self.wrap_model_output(noisy_next_obs, model_output, cs)\n91\t        return denoised\n92\t\n93\t    def forward(self, batch: Batch) -> LossAndLogs:\n94\t        n = self.cfg.inner_model.num_steps_conditioning\n95\t        seq_length = batch.obs.size(1) - n\n96\t\n97\t        all_obs = batch.obs.clone()\n98\t        loss = 0\n99\t\n100\t        for i in range(seq_length):\n101\t            obs = all_obs[:, i : n + i]\n102\t            next_obs = all_obs[:, n + i]\n103\t            act = batch.act[:, i : n + i]\n104\t            mask = batch.mask_padding[:, n + i]\n105\t\n106\t            b, t, c, h, w = obs.shape\n107\t            obs = obs.reshape(b, t * c, h, w)\n108\t\n109\t            sigma = self.sample_sigma_training(b, self.device)\n110\t            noisy_next_obs = self.apply_noise(next_obs, sigma, self.cfg.sigma_offset_noise)\n111\t\n112\t            cs = self.compute_conditioners(sigma)\n113\t            model_output = self.compute_model_output(noisy_next_obs, obs, act, cs)\n114\t\n115\t            target = (next_obs - cs.c_skip * noisy_next_obs) / cs.c_out\n116\t            loss += F.mse_loss(model_output[mask], target[mask])\n117\t\n118\t            denoised = self.wrap_model_output(noisy_next_obs, model_output, cs)\n119\t            all_obs[:, n + i] = denoised\n120\t\n121\t        loss /= seq_length\n122\t        return loss, {\"loss_denoising\": loss.detach()}\n123\t"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"6e7ba9d1-8e48-41e6-9935-49decba3af59","timestamp":"2026-04-05T08:29:19.179Z"}
