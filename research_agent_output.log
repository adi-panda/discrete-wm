{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TGTwZr55UUAZW8aPPikkxR","type":"tool_result","content":"1\timport math\n2\tfrom typing import Generator, List\n3\t\n4\timport torch\n5\timport torch.nn.functional as F\n6\t\n7\tfrom .batch import Batch\n8\tfrom .episode import Episode\n9\tfrom .segment import Segment, SegmentId\n10\t\n11\t\n12\tdef collate_segments_to_batch(segments: List[Segment]) -> Batch:\n13\t    attrs = (\"obs\", \"act\", \"rew\", \"end\", \"trunc\", \"mask_padding\")\n14\t    stack = (torch.stack([getattr(s, x) for s in segments]) for x in attrs)\n15\t    return Batch(*stack, [s.info for s in segments], [s.id for s in segments])\n16\t\n17\t\n18\tdef make_segment(episode: Episode, segment_id: SegmentId, should_pad: bool = True) -> Segment:\n19\t    assert segment_id.start < len(episode) and segment_id.stop > 0 and segment_id.start < segment_id.stop\n20\t    pad_len_right = max(0, segment_id.stop - len(episode))\n21\t    pad_len_left = max(0, -segment_id.start)\n22\t    assert pad_len_right == pad_len_left == 0 or should_pad\n23\t\n24\t    def pad(x):\n25\t        right = F.pad(x, [0 for _ in range(2 * x.ndim - 1)] + [pad_len_right]) if pad_len_right > 0 else x\n26\t        return F.pad(right, [0 for _ in range(2 * x.ndim - 2)] + [pad_len_left, 0]) if pad_len_left > 0 else right\n27\t\n28\t    start = max(0, segment_id.start)\n29\t    stop = min(len(episode), segment_id.stop)\n30\t    mask_padding = torch.cat((torch.zeros(pad_len_left), torch.ones(stop - start), torch.zeros(pad_len_right))).bool()\n31\t\n32\t    return Segment(\n33\t        pad(episode.obs[start:stop]),\n34\t        pad(episode.act[start:stop]),\n35\t        pad(episode.rew[start:stop]),\n36\t        pad(episode.end[start:stop]),\n37\t        pad(episode.trunc[start:stop]),\n38\t        mask_padding,\n39\t        info=episode.info,\n40\t        id=SegmentId(segment_id.episode_id, start, stop),\n41\t    )\n42\t\n43\t\n44\tclass DatasetTraverser:\n45\t    def __init__(self, dataset, batch_num_samples: int, chunk_size: int) -> None:\n46\t        self.dataset = dataset\n47\t        self.batch_num_samples = batch_num_samples\n48\t        self.chunk_size = chunk_size\n49\t\n50\t    def __len__(self):\n51\t        return math.ceil(\n52\t            sum(\n53\t                [\n54\t                    math.ceil(self.dataset.lengths[episode_id] / self.chunk_size)\n55\t                    - int(self.dataset.lengths[episode_id] % self.chunk_size == 1)\n56\t                    for episode_id in range(self.dataset.num_episodes)\n57\t                ]\n58\t            )\n59\t            / self.batch_num_samples\n60\t        )\n61\t\n62\t    def __iter__(self) -> Generator[Batch, None, None]:\n63\t        chunks = []\n64\t        for episode_id in range(self.dataset.num_episodes):\n65\t            episode = self.dataset.load_episode(episode_id)\n66\t            chunks.extend(\n67\t                make_segment(\n68\t                    episode,\n69\t                    SegmentId(episode_id, start=i * self.chunk_size, stop=(i + 1) * self.chunk_size),\n70\t                    should_pad=True,\n71\t                )\n72\t                for i in range(math.ceil(len(episode) / self.chunk_size))\n73\t            )\n74\t            if chunks[-1].effective_size < 2:\n75\t                chunks.pop()\n76\t\n77\t            while len(chunks) >= self.batch_num_samples:\n78\t                yield collate_segments_to_batch(chunks[: self.batch_num_samples])\n79\t                chunks = chunks[self.batch_num_samples :]\n80\t\n81\t        if len(chunks) > 0:\n82\t            yield collate_segments_to_batch(chunks)\n83\t"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"8abe5a3b-db6a-4601-9968-b117277f6447","timestamp":"2026-04-05T08:29:46.873Z"}
