device, global_step, args.sample_dir,","-                args.num_bins, num_samples=8, num_steps=args.gen_steps","+                model, tokenizer, dataset, device, global_step, args.sample_dir,","+                num_samples=8, num_steps=args.gen_steps","             )","             model.train()"," ","-        # Save checkpoint","         if global_step % args.save_every == 0:","             ckpt_path = os.path.join(args.ckpt_dir, f'model_step_{global_step:06d}.pt')","             torch.save({"]},{"oldStart":238,"oldLines":9,"newStart":302,"newLines":9,"lines":["                 'step': global_step,","                 'best_loss': best_loss,","                 'args': vars(args),","+                'tokenizer_args': tok_args,","             }, ckpt_path)"," ","-            # Also save as latest","             latest_path = os.path.join(args.ckpt_dir, 'model_latest.pt')","             torch.save({","                 'model': model.state_dict(),"]},{"oldStart":249,"oldLines":37,"newStart":313,"newLines":42,"lines":["                 'step': global_step,","                 'best_loss': best_loss,","                 'args': vars(args),","+                'tokenizer_args': tok_args,","             }, latest_path)"," ","             if loss_val < best_loss:","                 best_loss = loss_val","-                best_path = os.path.join(args.ckpt_dir, 'model_best.pt')","                 torch.save({","                     'model': model.state_dict(),","                     'step': global_step,","                     'loss': best_loss,","-                }, best_path)","+                    'args': vars(args),","+                    'tokenizer_args': tok_args,","+                }, os.path.join(args.ckpt_dir, 'model_best.pt'))"," ","     csv_file.close()","     print(f\"\\nTraining complete. {global_step} steps in {time.time() - start_time:.0f}s\")","-    print(f\"Checkpoints saved to {args.ckpt_dir}\")"," "," "," if __name__ == \"__main__\":","     parser = argparse.ArgumentParser()"," ","+    # Mode","+    parser.add_argument(\"--pretokenize\", action=\"store_true\")","+    parser.add_argument(\"--raw-data\", default=\"/root/research/discrete_wm/data/atari_data.npz\")","+    parser.add_argument(\"--tokenizer-ckpt\", default=\"/root/research/checkpoints/tokenizer_final.pt\")","+","     # Data","-    parser.add_argument(\"--data\", default=\"/root/research/discrete_wm/data/atari_data.npz\")","-    parser.add_argument(\"--num-bins\", type=int, default=64)","+    parser.add_argument(\"--data\", default=\"/root/research/discrete_wm/data/tokenized_data.npz\")"," ","     # Model","-    parser.add_argument(\"--d-model\", type=int, default=384)","+    parser.add_argument(\"--d-model\", type=int, default=512)","     parser.add_argument(\"--n-layers\", type=int, default=8)","-    parser.add_argument(\"--n-heads\", type=int, default=6)","+    parser.add_argument(\"--n-heads\", type=int, default=8)","     parser.add_argument(\"--dropout\", type=float, default=0.0)"," ","     # Training","-    parser.add_argument(\"--batch-size\", type=int, default=32)","+    parser.add_argument(\"--batch-size\", type=int, default=128)","     parser.add_argument(\"--lr\", type=float, default=1e-4)","     parser.add_argument(\"--weight-decay\", type=float, default=0.01)","     parser.add_argument(\"--warmup-steps\", type=int, default=1000)"]},{"oldStart":299,"oldLines":8,"newStart":368,"newLines":10,"lines":[" ","     args = parser.parse_args()"," ","-    os.makedirs(args.ckpt_dir, exist_ok=True)","-    os.makedirs(args.log_dir, exist_ok=True)","-    os.makedirs(args.sample_dir, exist_ok=True)","-","-    train(args)","+    if args.pretokenize:","+        pretokenize_dataset(args)","+    else:","+        os.makedirs(args.ckpt_dir, exist_ok=True)","+        os.makedirs(args.log_dir, exist_ok=True)","+        os.makedirs(args.sample_dir, exist_ok=True)","+        train(args)"]}],"originalFile":"\"\"\"\nTraining script for the discrete diffusion world model.\n\nUsage:\n    python train_world_model.py --data data/atari_data.npz --steps 200000\n\"\"\"\n\nimport argparse\nimport math\nimport os\nimport time\nimport csv\n\nimport torch\nimport torch.nn.functional as F\nfrom torch.utils.data import DataLoader\nfrom tqdm import tqdm\n\nfrom models.discrete_diffusion import DiscreteWorldModel, tokenize_frames, detokenize_frames\nfrom utils import AtariFramePairDataset, cosine_mask_schedule\n\n\ndef save_sample_images(model, dataset, device, step, save_dir, num_bins, num_samples=8, num_steps=8):\n    \"\"\"Generate and save sample predictions.\"\"\"\n    import imageio\n    import numpy as np\n\n    model.eval()\n    os.makedirs(save_dir, exist_ok=True)\n\n    # Get some test samples\n    indices = list(range(0, min(num_samples * 10, len(dataset)), 10))[:num_samples]\n    prev_tokens_list = []\n    actions_list = []\n    gt_tokens_list = []\n\n    for idx in indices:\n        pt, a, nt = dataset[idx]\n        prev_tokens_list.append(pt)\n        actions_list.append(a)\n        gt_tokens_list.append(nt)\n\n    prev_tokens = torch.stack(prev_tokens_list).to(device)\n    actions = torch.stack(actions_list).to(device)\n    gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n    # Generate predictions\n    with torch.no_grad():\n        pred_tokens = model.generate(prev_tokens, actions, num_steps=num_steps, temperature=0.9, device=device)\n\n    # Detokenize\n    pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins).cpu().numpy()\n    gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins).cpu().numpy()\n    prev_frames = detokenize_frames(prev_tokens, num_bins=num_bins).cpu().numpy()\n\n    # Create comparison grid\n    rows = []\n    for i in range(min(num_samples, len(pred_frames))):\n        # prev | gt_next | predicted_next\n        row = np.concatenate([prev_frames[i], gt_frames[i], pred_frames[i]], axis=1)\n        rows.append(row)\n\n    grid = np.concatenate(rows, axis=0)\n    imageio.imwrite(os.path.join(save_dir, f'samples_step_{step:06d}.png'), grid)\n\n    model.train()\n    return pred_frames, gt_frames\n\n\ndef train(args):\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n    print(f\"Using device: {device}\")\n\n    # Dataset\n    dataset = AtariFramePairDataset(args.data, num_bins=args.num_bins)\n    dataloader = DataLoader(\n        dataset, batch_size=args.batch_size, shuffle=True,\n        num_workers=4, pin_memory=True, drop_last=True,\n        persistent_workers=True,\n    )\n\n    # Model\n    model = DiscreteWorldModel(\n        vocab_size=args.num_bins,\n        num_channels=3,\n        spatial_h=64,\n        spatial_w=64,\n        d_model=args.d_model,\n        n_layers=args.n_layers,\n        n_heads=args.n_heads,\n        n_actions=dataset.num_actions,\n        dropout=args.dropout,\n        cond_dim=args.d_model,\n    ).to(device)\n\n    num_params = sum(p.numel() for p in model.parameters())\n    print(f\"Model parameters: {num_params:,} ({num_params / 1e6:.1f}M)\")\n\n    # Optimizer\n    optimizer = torch.optim.AdamW(\n        model.parameters(), lr=args.lr, weight_decay=args.weight_decay,\n        betas=(0.9, 0.95),\n    )\n\n    # LR schedule: warmup + cosine decay\n    def lr_lambda(step):\n        if step < args.warmup_steps:\n            return step / max(1, args.warmup_steps)\n        progress = (step - args.warmup_steps) / max(1, args.total_steps - args.warmup_steps)\n        return 0.5 * (1.0 + math.cos(math.pi * progress))\n\n    scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)\n\n    # Training state\n    global_step = 0\n    best_loss = float('inf')\n\n    # CSV logging\n    os.makedirs(args.log_dir, exist_ok=True)\n    csv_path = os.path.join(args.log_dir, 'training_log.csv')\n    csv_file = open(csv_path, 'w', newline='')\n    csv_writer = csv.writer(csv_file)\n    csv_writer.writerow(['step', 'loss', 'lr', 'time', 'mask_ratio_mean'])\n\n    # Checkpoint resume\n    if args.resume and os.path.exists(args.resume):\n        ckpt = torch.load(args.resume, map_location=device)\n        model.load_state_dict(ckpt['model'])\n        optimizer.load_state_dict(ckpt['optimizer'])\n        scheduler.load_state_dict(ckpt['scheduler'])\n        global_step = ckpt['step']\n        best_loss = ckpt.get('best_loss', float('inf'))\n        print(f\"Resumed from step {global_step}\")\n\n    # Enable mixed precision\n    scaler = torch.amp.GradScaler('cuda')\n    mask_token_id = args.num_bins  # MASK token\n\n    print(f\"\\nStarting training for {args.total_steps} steps...\")\n    print(f\"Batch size: {args.batch_size}, LR: {args.lr}\")\n    print(f\"Model: {args.n_layers} layers, {args.d_model} dim, {args.n_heads} heads\")\n    print(f\"Vocab: {args.num_bins} bins + 1 MASK token\")\n\n    model.train()\n    data_iter = iter(dataloader)\n    start_time = time.time()\n    running_loss = 0.0\n    log_interval = 100\n\n    pbar = tqdm(range(global_step, args.total_steps), desc=\"Training\")\n\n    for step_idx in pbar:\n        # Get batch\n        try:\n            prev_tokens, actions, next_tokens = next(data_iter)\n        except StopIteration:\n            data_iter = iter(dataloader)\n            prev_tokens, actions, next_tokens = next(data_iter)\n\n        prev_tokens = prev_tokens.to(device)\n        actions = actions.to(device)\n        next_tokens = next_tokens.to(device)\n\n        B, N, C = next_tokens.shape\n\n        # Sample masking ratio from cosine schedule\n        t = torch.rand(B, device=device)\n        mask_ratio = cosine_mask_schedule(t)  # [B]\n\n        # Create pixel-level mask (same mask across channels for each pixel)\n        mask = torch.rand(B, N, device=device) < mask_ratio.unsqueeze(1)  # [B, N]\n\n        # Create masked version of next_tokens\n        masked_next = next_tokens.clone()\n        for c in range(C):\n            masked_next[:, :, c] = torch.where(mask, mask_token_id, next_tokens[:, :, c])\n\n        # Forward pass with mixed precision\n        with torch.amp.autocast('cuda', dtype=torch.bfloat16):\n            logits = model(masked_next, prev_tokens, actions, mask_ratio)  # list of [B, N, V]\n\n            # Loss: cross-entropy on masked positions only, per channel\n            total_loss = 0.0\n            for c in range(C):\n                # Only compute loss on masked positions\n                logits_c = logits[c][mask]  # [num_masked, V]\n                targets_c = next_tokens[:, :, c][mask]  # [num_masked]\n                if logits_c.numel() > 0:\n                    total_loss = total_loss + F.cross_entropy(logits_c, targets_c)\n\n            total_loss = total_loss / C  # Average across channels\n\n        # Backward\n        optimizer.zero_grad()\n        scaler.scale(total_loss).backward()\n        scaler.unscale_(optimizer)\n        torch.nn.utils.clip_grad_norm_(model.parameters(), args.grad_clip)\n        scaler.step(optimizer)\n        scaler.update()\n        scheduler.step()\n\n        global_step += 1\n        loss_val = total_loss.item()\n        running_loss += loss_val\n\n        # Logging\n        if global_step % log_interval == 0:\n            avg_loss = running_loss / log_interval\n            lr = scheduler.get_last_lr()[0]\n            elapsed = time.time() - start_time\n            steps_per_sec = global_step / elapsed\n\n            csv_writer.writerow([global_step, avg_loss, lr, elapsed, mask_ratio.mean().item()])\n            csv_file.flush()\n\n            pbar.set_postfix({\n                'loss': f'{avg_loss:.4f}',\n                'lr': f'{lr:.2e}',\n                'sps': f'{steps_per_sec:.1f}',\n            })\n            running_loss = 0.0\n\n        # Save samples\n        if global_step % args.sample_every == 0:\n            save_sample_images(\n                model, dataset, device, global_step, args.sample_dir,\n                args.num_bins, num_samples=8, num_steps=args.gen_steps\n            )\n            model.train()\n\n        # Save checkpoint\n        if global_step % args.save_every == 0:\n            ckpt_path = os.path.join(args.ckpt_dir, f'model_step_{global_step:06d}.pt')\n            torch.save({\n                'model': model.state_dict(),\n                'optimizer': optimizer.state_dict(),\n                'scheduler': scheduler.state_dict(),\n                'step': global_step,\n                'best_loss': best_loss,\n                'args': vars(args),\n            }, ckpt_path)\n\n            # Also save as latest\n            latest_path = os.path.join(args.ckpt_dir, 'model_latest.pt')\n            torch.save({\n                'model': model.state_dict(),\n                'optimizer': optimizer.state_dict(),\n                'scheduler': scheduler.state_dict(),\n                'step': global_step,\n                'best_loss': best_loss,\n                'args': vars(args),\n            }, latest_path)\n\n            if loss_val < best_loss:\n                best_loss = loss_val\n                best_path = os.path.join(args.ckpt_dir, 'model_best.pt')\n                torch.save({\n                    'model': model.state_dict(),\n                    'step': global_step,\n                    'loss': best_loss,\n                }, best_path)\n\n    csv_file.close()\n    print(f\"\\nTraining complete. {global_step} steps in {time.time() - start_time:.0f}s\")\n    print(f\"Checkpoints saved to {args.ckpt_dir}\")\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser()\n\n    # Data\n    parser.add_argument(\"--data\", default=\"/root/research/discrete_wm/data/atari_data.npz\")\n    parser.add_argument(\"--num-bins\", type=int, default=64)\n\n    # Model\n    parser.add_argument(\"--d-model\", type=int, default=384)\n    parser.add_argument(\"--n-layers\", type=int, default=8)\n    parser.add_argument(\"--n-heads\", type=int, default=6)\n    parser.add_argument(\"--dropout\", type=float, default=0.0)\n\n    # Training\n    parser.add_argument(\"--batch-size\", type=int, default=32)\n    parser.add_argument(\"--lr\", type=float, default=1e-4)\n    parser.add_argument(\"--weight-decay\", type=float, default=0.01)\n    parser.add_argument(\"--warmup-steps\", type=int, default=1000)\n    parser.add_argument(\"--total-steps\", type=int, default=200000)\n    parser.add_argument(\"--grad-clip\", type=float, default=1.0)\n\n    # Inference\n    parser.add_argument(\"--gen-steps\", type=int, default=8)\n\n    # Checkpointing\n    parser.add_argument(\"--ckpt-dir\", default=\"/root/research/checkpoints\")\n    parser.add_argument(\"--log-dir\", default=\"/root/research/logs\")\n    parser.add_argument(\"--sample-dir\", default=\"/root/research/figures/samples\")\n    parser.add_argument(\"--save-every\", type=int, default=20000)\n    parser.add_argument(\"--sample-every\", type=int, default=10000)\n    parser.add_argument(\"--resume\", default=None)\n\n    args = parser.parse_args()\n\n    os.makedirs(args.ckpt_dir, exist_ok=True)\n    os.makedirs(args.log_dir, exist_ok=True)\n    os.makedirs(args.sample_dir, exist_ok=True)\n\n    train(args)\n"}}
