{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Ayz8UsphZdkE7Bg1cktGJ","type":"tool_result","content":"1\t\"\"\"\n2\tDerived from https://github.com/openai/gym/blob/master/gym/wrappers/atari_preprocessing.py\n3\tImplementation of Atari 2600 Preprocessing following the guidelines of Machado et al., 2018.\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\tfrom typing import Any, SupportsFloat\n9\t\n10\timport cv2\n11\timport numpy as np\n12\t\n13\timport gymnasium as gym\n14\tfrom gymnasium.core import WrapperActType, WrapperObsType\n15\tfrom gymnasium.spaces import Box\n16\t\n17\t\n18\tclass AtariPreprocessing(gym.Wrapper, gym.utils.RecordConstructorArgs):\n19\t    def __init__(\n20\t        self,\n21\t        env: gym.Env,\n22\t        noop_max: int,\n23\t        frame_skip: int,\n24\t        screen_size: int,\n25\t    ):\n26\t        gym.utils.RecordConstructorArgs.__init__(\n27\t            self,\n28\t            noop_max=noop_max,\n29\t            frame_skip=frame_skip,\n30\t            screen_size=screen_size,\n31\t        )\n32\t        gym.Wrapper.__init__(self, env)\n33\t\n34\t        assert frame_skip > 0\n35\t        assert screen_size > 0\n36\t        assert noop_max >= 0\n37\t        if frame_skip > 1 and getattr(env.unwrapped, \"_frameskip\", None) != 1:\n38\t            raise ValueError(\n39\t                \"Disable frame-skipping in the original env. Otherwise, more than one frame-skip will happen as through this wrapper\"\n40\t            )\n41\t        self.noop_max = noop_max\n42\t        assert env.unwrapped.get_action_meanings()[0] == \"NOOP\"\n43\t\n44\t        self.frame_skip = frame_skip\n45\t        self.screen_size = screen_size\n46\t\n47\t        # buffer of most recent two observations for max pooling\n48\t        assert isinstance(env.observation_space, Box)\n49\t        self.obs_buffer = [\n50\t            np.empty(env.observation_space.shape, dtype=np.uint8),\n51\t            np.empty(env.observation_space.shape, dtype=np.uint8),\n52\t        ]\n53\t\n54\t        self.lives = 0\n55\t        self.game_over = False\n56\t\n57\t        _low, _high, _obs_dtype = (0, 255, np.uint8)\n58\t        _shape = (screen_size, screen_size, 3)\n59\t        self.observation_space = Box(low=_low, high=_high, shape=_shape, dtype=_obs_dtype)\n60\t\n61\t    @property\n62\t    def ale(self):\n63\t        \"\"\"Make ale as a class property to avoid serialization error.\"\"\"\n64\t        return self.env.unwrapped.ale\n65\t\n66\t    def step(self, action: WrapperActType) -> tuple[WrapperObsType, SupportsFloat, bool, bool, dict[str, Any]]:\n67\t        total_reward, terminated, truncated, info = 0.0, False, False, {}\n68\t\n69\t        life_loss = False\n70\t\n71\t        for t in range(self.frame_skip):\n72\t            _, reward, terminated, truncated, info = self.env.step(action)\n73\t            total_reward += reward\n74\t            self.game_over = terminated\n75\t\n76\t            if self.ale.lives() < self.lives:\n77\t                life_loss = True\n78\t                self.lives = self.ale.lives()\n79\t\n80\t            if terminated or truncated:\n81\t                break\n82\t\n83\t            if t == self.frame_skip - 2:\n84\t                self.ale.getScreenRGB(self.obs_buffer[1])\n85\t            elif t == self.frame_skip - 1:\n86\t                self.ale.getScreenRGB(self.obs_buffer[0])\n87\t\n88\t        info[\"life_loss\"] = life_loss\n89\t\n90\t        obs, original_obs = self._get_obs()\n91\t        info[\"original_obs\"] = original_obs\n92\t\n93\t        return obs, total_reward, terminated, truncated, info\n94\t\n95\t    def reset(\n96\t        self, *, seed: int | None = None, options: dict[str, Any] | None = None\n97\t    ) -> tuple[WrapperObsType, dict[str, Any]]:\n98\t        \"\"\"Resets the environment using preprocessing.\"\"\"\n99\t        # NoopReset\n100\t        _, reset_info = self.env.reset(seed=seed, options=options)\n101\t\n102\t        reset_info[\"life_loss\"] = False\n103\t\n104\t        noops = self.env.unwrapped.np_random.integers(1, self.noop_max + 1) if self.noop_max > 0 else 0\n105\t        for _ in range(noops):\n106\t            _, _, terminated, truncated, step_info = self.env.step(0)\n107\t            reset_info.update(step_info)\n108\t            if terminated or truncated:\n109\t                _, reset_info = self.env.reset(seed=seed, options=options)\n110\t\n111\t        self.lives = self.ale.lives()\n112\t        self.ale.getScreenRGB(self.obs_buffer[0])\n113\t        self.obs_buffer[1].fill(0)\n114\t\n115\t        obs, original_obs = self._get_obs()\n116\t        reset_info[\"original_obs\"] = original_obs\n117\t\n118\t        return obs, reset_info\n119\t\n120\t    def _get_obs(self):\n121\t        if self.frame_skip > 1:  # more efficient in-place pooling\n122\t            np.maximum(self.obs_buffer[0], self.obs_buffer[1], out=self.obs_buffer[0])\n123\t\n124\t        original_obs = self.obs_buffer[0]\n125\t        obs = cv2.resize(\n126\t            original_obs,\n127\t            (self.screen_size, self.screen_size),\n128\t            interpolation=cv2.INTER_AREA,\n129\t        )\n130\t\n131\t        obs = np.asarray(obs, dtype=np.uint8)\n132\t\n133\t        return obs, original_obs\n134\t"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"9e134164-4de9-4cbc-9483-0d7966ea4faa","timestamp":"2026-04-05T08:29:20.986Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmoqNLJucUBfJWP3rk96aw","type":"tool_result","content":"1\tfrom collections import Counter\n2\timport multiprocessing as mp\n3\tfrom pathlib import Path\n4\timport shutil\n5\tfrom typing import Any, Dict, List, Optional\n6\t\n7\timport numpy as np\n8\timport torch\n9\t\n10\tfrom .episode import Episode\n11\tfrom .segment import Segment, SegmentId\n12\tfrom .utils import make_segment\n13\tfrom utils import StateDictMixin\n14\t\n15\t\n16\tclass Dataset(StateDictMixin, torch.utils.data.Dataset):\n17\t    def __init__(\n18\t        self,\n19\t        directory: Path,\n20\t        name: Optional[str] = None,\n21\t        cache_in_ram: bool = False,\n22\t        use_manager: bool = False,\n23\t        save_on_disk: bool = True,\n24\t    ) -> None:\n25\t        super().__init__()\n26\t\n27\t        # State\n28\t        self.is_static = False\n29\t        self.num_episodes = None\n30\t        self.num_steps = None\n31\t        self.start_idx = None\n32\t        self.lengths = None\n33\t        self.counter_rew = None\n34\t        self.counter_end = None\n35\t\n36\t        self._directory = Path(directory).expanduser()\n37\t        self._name = name if name is not None else self._directory.stem\n38\t        self._cache_in_ram = cache_in_ram\n39\t        self._save_on_disk = save_on_disk\n40\t        self._default_path = self._directory / \"info.pt\"\n41\t        self._cache = mp.Manager().dict() if use_manager else {}\n42\t        self._reset()\n43\t\n44\t    def __len__(self) -> int:\n45\t        return self.num_steps\n46\t\n47\t    def __getitem__(self, segment_id: SegmentId) -> Segment:\n48\t        episode = self.load_episode(segment_id.episode_id)\n49\t        return make_segment(episode, segment_id, should_pad=True)\n50\t\n51\t    def __str__(self) -> str:\n52\t        return f\"{self.name}: {self.num_episodes} episodes, {self.num_steps} steps.\"\n53\t\n54\t    @property\n55\t    def name(self) -> str:\n56\t        return self._name\n57\t\n58\t    @property\n59\t    def counts_rew(self) -> List[int]:\n60\t        return [self.counter_rew[r] for r in [-1, 0, 1]]\n61\t\n62\t    @property\n63\t    def counts_end(self) -> List[int]:\n64\t        return [self.counter_end[e] for e in [0, 1]]\n65\t\n66\t    def _reset(self) -> None:\n67\t        self.num_episodes = 0\n68\t        self.num_steps = 0\n69\t        self.start_idx = np.array([], dtype=np.int64)\n70\t        self.lengths = np.array([], dtype=np.int64)\n71\t        self.counter_rew = Counter()\n72\t        self.counter_end = Counter()\n73\t        self._cache.clear()\n74\t\n75\t    def clear(self) -> None:\n76\t        self.assert_not_static()\n77\t        if self._directory.is_dir():\n78\t            shutil.rmtree(self._directory)\n79\t        self._reset()\n80\t\n81\t    def load_episode(self, episode_id: int) -> Episode:\n82\t        if self._cache_in_ram and episode_id in self._cache:\n83\t            episode = self._cache[episode_id]\n84\t        else:\n85\t            episode = Episode.load(self._get_episode_path(episode_id))\n86\t            if self._cache_in_ram:\n87\t                self._cache[episode_id] = episode\n88\t        return episode\n89\t\n90\t    def add_episode(self, episode: Episode, *, episode_id: Optional[int] = None) -> int:\n91\t        self.assert_not_static()\n92\t        episode = episode.to(\"cpu\")\n93\t\n94\t        if episode_id is None:\n95\t            episode_id = self.num_episodes\n96\t            self.start_idx = np.concatenate((self.start_idx, np.array([self.num_steps])))\n97\t            self.lengths = np.concatenate((self.lengths, np.array([len(episode)])))\n98\t            self.num_steps += len(episode)\n99\t            self.num_episodes += 1\n100\t\n101\t        else:\n102\t            assert episode_id < self.num_episodes\n103\t            old_episode = self.load_episode(episode_id)\n104\t            incr_num_steps = len(episode) - len(old_episode)\n105\t            self.lengths[episode_id] = len(episode)\n106\t            self.start_idx[episode_id + 1 :] += incr_num_steps\n107\t            self.num_steps += incr_num_steps\n108\t            self.counter_rew.subtract(old_episode.rew.sign().tolist())\n109\t            self.counter_end.subtract(old_episode.end.tolist())\n110\t\n111\t        self.counter_rew.update(episode.rew.sign().tolist())\n112\t        self.counter_end.update(episode.end.tolist())\n113\t\n114\t        if self._save_on_disk:\n115\t            episode.save(self._get_episode_path(episode_id))\n116\t\n117\t        if self._cache_in_ram:\n118\t            self._cache[episode_id] = episode\n119\t\n120\t        return episode_id\n121\t\n122\t    def _get_episode_path(self, episode_id: int) -> Path:\n123\t        n = 3  # number of hierarchies\n124\t        powers = np.arange(n)\n125\t        subfolders = np.floor((episode_id % 10 ** (1 + powers)) / 10**powers) * 10**powers\n126\t        subfolders = [int(x) for x in subfolders[::-1]]\n127\t        subfolders = \"/\".join([f\"{x:0{n - i}d}\" for i, x in enumerate(subfolders)])\n128\t        return self._directory / subfolders / f\"{episode_id}.pt\"\n129\t\n130\t    def load_state_dict(self, state_dict: Dict[str, Any]) -> None:\n131\t        super().load_state_dict(state_dict)\n132\t        self._cache.clear()\n133\t\n134\t    def assert_not_static(self) -> None:\n135\t        assert not self.is_static, \"Trying to modify a static dataset.\"\n136\t\n137\t    def save_to_default_path(self) -> None:\n138\t        self._default_path.parent.mkdir(exist_ok=True, parents=True)\n139\t        torch.save(self.state_dict(), self._default_path)\n140\t\n141\t    def load_from_default_path(self) -> None:\n142\t        if self._default_path.is_file():\n143\t            self.load_state_dict(torch.load(self._default_path))\n144\t"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"8d2e3c39-9f48-45ad-81e7-b64ab6b66cab","timestamp":"2026-04-05T08:29:21.005Z"}
