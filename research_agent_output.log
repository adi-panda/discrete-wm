,","         n_layers=args.n_layers,","         n_heads=args.n_heads,"]},{"oldStart":111,"oldLines":7,"newStart":185,"newLines":6,"lines":[" ","     scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)"," ","-    # Training state","     global_step = 0","     best_loss = float('inf')"," "]},{"oldStart":122,"oldLines":7,"newStart":195,"newLines":7,"lines":["     csv_writer = csv.writer(csv_file)","     csv_writer.writerow(['step', 'loss', 'lr', 'time', 'mask_ratio_mean'])"," ","-    # Checkpoint resume","+    # Resume","     if args.resume and os.path.exists(args.resume):","         ckpt = torch.load(args.resume, map_location=device)","         model.load_state_dict(ckpt['model'])"]},{"oldStart":132,"oldLines":14,"newStart":205,"newLines":15,"lines":["         best_loss = ckpt.get('best_loss', float('inf'))","         print(f\"Resumed from step {global_step}\")"," ","-    # Enable mixed precision","+    # Mixed precision","     scaler = torch.amp.GradScaler('cuda')","-    mask_token_id = args.num_bins  # MASK token","+    mask_token_id = tok_args['vocab_size']"," ","     print(f\"\\nStarting training for {args.total_steps} steps...\")","     print(f\"Batch size: {args.batch_size}, LR: {args.lr}\")","-    print(f\"Model: {args.n_layers} layers, {args.d_model} dim, {args.n_heads} heads\")","-    print(f\"Vocab: {args.num_bins} bins + 1 MASK token\")","+    print(f\"Model: {args.n_layers}L, {args.d_model}D, {args.n_heads}H\")","+    print(f\"Vocab: {tok_args['vocab_size']} codes, grid: {grid_size}x{grid_size} = \"","+          f\"{grid_size**2} tokens/frame\")"," ","     model.train()","     data_iter = iter(dataloader)"]},{"oldStart":150,"oldLines":49,"newStart":224,"newLines":42,"lines":["     pbar = tqdm(range(global_step, args.total_steps), desc=\"Training\")"," ","     for step_idx in pbar:","-        # Get batch","         try:","             prev_tokens, actions, next_tokens = next(data_iter)","         except StopIteration:","             data_ite