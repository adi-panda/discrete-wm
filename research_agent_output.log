{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016LPzaeQiaetr8ysLTHCNph","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011abMERTjZhDfH8VwQ5dMof","name":"Write","input":{"file_path":"/root/research/discrete_wm/utils.py","content":"\"\"\"Utility functions for the discrete diffusion world model.\"\"\"\n\nimport math\nimport torch\nimport numpy as np\nfrom torch.utils.data import Dataset\n\n\nclass AtariFramePairDataset(Dataset):\n    \"\"\"Dataset of (prev_frame, action, next_frame) triples from collected Atari data.\"\"\"\n\n    def __init__(self, data_path, num_bins=64):\n        data = np.load(data_path)\n        self.frames = data['frames']  # [N, 64, 64, 3] uint8\n        self.actions = data['actions']  # [N-1] int64\n        self.num_actions = int(data['num_actions'])\n        self.num_bins = num_bins\n\n        # Build valid indices: pairs where both frames are from same episode\n        # We skip indices where we'd cross an episode boundary\n        # (episode boundaries have a dummy action=0 and a reset frame)\n        self.valid_indices = []\n        for i in range(len(self.actions)):\n            # A simple heuristic: if consecutive frames exist, they're valid pairs\n            # Episode boundaries are marked by the extra frame after reset\n            if i < len(self.frames) - 1:\n                self.valid_indices.append(i)\n\n        print(f\"Dataset: {len(self.valid_indices)} valid frame pairs, \"\n              f\"{self.num_actions} actions, {self.num_bins} bins\")\n\n    def __len__(self):\n        return len(self.valid_indices)\n\n    def __getitem__(self, idx):\n        i = self.valid_indices[idx]\n\n        prev_frame = torch.from_numpy(self.frames[i].copy()).float()      # [64, 64, 3]\n        next_frame = torch.from_numpy(self.frames[i + 1].copy()).float()  # [64, 64, 3]\n        action = self.actions[i]\n\n        # Quantize to discrete tokens\n        prev_tokens = (prev_frame / 256.0 * self.num_bins).long().clamp(0, self.num_bins - 1)\n        next_tokens = (next_frame / 256.0 * self.num_bins).long().clamp(0, self.num_bins - 1)\n\n        # Reshape to [H*W, C]\n        prev_tokens = prev_tokens.reshape(-1, 3)   # [4096, 3]\n        next_tokens = next_tokens.reshape(-1, 3)   # [4096, 3]\n\n        return prev_tokens, torch.tensor(action, dtype=torch.long), next_tokens\n\n\ndef cosine_mask_schedule(t):\n    \"\"\"Cosine masking schedule. t in [0, 1] -> mask ratio in [0, 1].\"\"\"\n    return torch.cos(t * math.pi / 2)\n\n\ndef compute_psnr(pred, target):\n    \"\"\"Compute PSNR between predicted and target uint8 images.\"\"\"\n    mse = ((pred.float() - target.float()) ** 2).mean()\n    if mse == 0:\n        return float('inf')\n    return 10 * math.log10(255.0 ** 2 / mse.item())\n\n\ndef compute_ssim_simple(pred, target):\n    \"\"\"Simple SSIM computation for uint8 images (per-image, averaged).\"\"\"\n    # Convert to float\n    pred = pred.float() / 255.0\n    target = target.float() / 255.0\n\n    C1 = 0.01 ** 2\n    C2 = 0.03 ** 2\n\n    mu_p = pred.mean(dim=(-3, -2, -1))\n    mu_t = target.mean(dim=(-3, -2, -1))\n\n    sigma_p_sq = pred.var(dim=(-3, -2, -1))\n    sigma_t_sq = target.var(dim=(-3, -2, -1))\n    sigma_pt = ((pred - pred.mean(dim=(-3, -2, -1), keepdim=True)) *\n                (target - target.mean(dim=(-3, -2, -1), keepdim=True))).mean(dim=(-3, -2, -1))\n\n    ssim = ((2 * mu_p * mu_t + C1) * (2 * sigma_pt + C2)) / \\\n           ((mu_p ** 2 + mu_t ** 2 + C1) * (sigma_p_sq + sigma_t_sq + C2))\n\n    return ssim.mean().item()\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4032,"cache_read_input_tokens":34829,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4032},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6eb3f8