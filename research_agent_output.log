_per_frame': ms_per_frame}","-        print(f\"  Steps={gen_steps}: {fps:.1f} FPS ({ms_per_frame:.1f} ms/frame)\")","-","     return results"," "," "," @torch.no_grad()","-def evaluate_long_horizon(model, dataset, device, num_bins, num_rollouts=10,","+def evaluate_long_horizon(model, tokenizer, dataset, device, num_rollouts=10,","                           rollout_length=50, gen_steps=8, temperature=0.9, save_dir=None):","-    \"\"\"Generate long autoregressive rollouts and measure quality degradation.\"\"\"","+    \"\"\"Autoregressive rollout quality.\"\"\"","     model.eval()","-","     if save_dir:","         os.makedirs(save_dir, exist_ok=True)"," ","-    all_psnr_by_step = [[] for _ in range(rollout_length)]","+    all_psnr = [[] for _ in range(rollout_length)]"," ","-    for r in tqdm(range(num_rollouts), desc=\"Long-horizon rollouts\"):","-        # Get a starting frame and sequence of actions","-        start_idx = r * 100  # Spread out across dataset","+    for r in tqdm(range(num_rollouts), desc=\"Long-horizon\"):","+        start_idx = r * 100","         if start_idx + rollout_length >= len(dataset):","             start_idx = 0"," ","-        pt, a, nt = dataset[start_idx]","-        current_tokens = pt.unsqueeze(0).to(device)","+        pt, _, _ = dataset[start_idx]","+        current = pt.unsqueeze(0).to(device).long()"," ","-        rollout_frames = []","+        pred_frames_list = []","         gt_frames_list = []"," ","         for step in range(rollout_length):"]},{"oldStart":224,"oldLines":199,"newStart":220,"newLines":172,"lines":["             _, action, gt_next = dataset[idx]","             action = action.unsqueeze(0).to(device)"," ","-            # Generate next frame","-            pred_tokens = model.generate(","-                current_tokens, action, num_steps=gen_steps,","-                temperature=temperature, device=device","-            )","+            pred = model.generate(current, action, num_steps=gen_steps,","+                 