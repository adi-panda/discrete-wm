" ","         Returns:","-            tokens: [B, H*W, C] - generated frame tokens","+            tokens: [B, N] - generated frame tokens","         \"\"\"","-        B, N, C = prev_tokens.shape","+        B, N = prev_tokens.shape"," ","         # Start fully masked","-        tokens = torch.full((B, N, C), self.mask_token_id, device=device, dtype=torch.long)","-        # Track which positions are still masked (per pixel, all channels masked together)","+        tokens = torch.full((B, N), self.mask_token_id, device=device, dtype=torch.long)","         is_masked = torch.ones(B, N, dtype=torch.bool, device=device)"," ","         for step in range(num_steps):","-            # Current mask ratio (decreasing from ~1 to ~0)","             ratio = 1.0 - (step + 1) / num_steps","-            mask_ratio_tensor = torch.full((B,), ratio, device=device)","+            mask_ratio_tensor = torch.full((B,), max(ratio, 0.0), device=device)"," ","             # Get predictions","             logits = self.forward(tokens, prev_tokens, action, mask_ratio_tensor)"," ","-            # For each channel, compute confidence","-            all_probs = []","-            all_sampled = []","-            for c in range(C):","-                probs_c = F.softmax(logits[c] / temperature, dim=-1)  # [B, N, V]","-                sampled_c = torch.multinomial(probs_c.view(-1, self.vocab_size), 1).view(B, N)","-                confidence_c = probs_c.max(dim=-1).values  # [B, N]","-                all_probs.append(confidence_c)","-                all_sampled.append(sampled_c)","+            # Sample from predicted distribution","+            probs = F.softmax(logits / temperature, dim=-1)  # [B, N, V]","+            sampled = torch.multinomial(probs.view(-1, self.vocab_size), 1).view(B, N)","+            confidence = probs.max(dim=-1).values  # [B, N]"," ","-            # Average confidence across channels","-            avg_confidence = torch.stack(all_probs, dim=-1).mean(dim=-1)  # [B, N]","+      