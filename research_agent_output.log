ne):","-        # Self-attention with AdaLN","+    def forward(self, x, cond, context):","+        # Self-attention","         h = self.adaln1(x, cond)","         h, _ = self.attn(h, h, h)","         x = x + h"," ","-        # Cross-attention to previous frame context","-        if self.use_cross_attn and context is not None:","-            h = self.adaln_cross(x, cond)","-            h, _ = self.cross_attn(h, context, context)","-            x = x + h","+        # Cross-attention to previous frame","+        h = self.adaln_cross(x, cond)","+        h, _ = self.cross_attn(h, context, context)","+        x = x + h"," ","-        # FFN with AdaLN","+        # FFN","         h = self.adaln2(x, cond)","         h = self.ffn(h)","         x = x + h"]},{"oldStart":90,"oldLines":7,"newStart":192,"newLines":7,"lines":["         return x"," "," ","-# --- Main Model ---","+# --- Main Discrete Diffusion Model ---"," "," class DiscreteWorldModel(nn.Module):","     \"\"\""]},{"oldStart":98,"oldLines":39,"newStart":200,"newLines":35,"lines":[" ","     Given previous frame tokens + action, predicts next frame tokens.","     Uses cosine masking schedule and iterative unmasking for generation.","+","+    Token grid: 16x16 = 256 tokens per frame (from 4x4 patches of 64x64 frames).","     \"\"\"","     def __init__(","         self,","-        vocab_size=64,          # Number of discrete bins per channel","-        num_channels=3,         # RGB","-        spatial_h=64,           # Frame height","-        spatial_w=64,           # Frame width","-        d_model=384,            # Transformer dimension","+        vocab_size=512,         # Codebook size for patch tokens","+        grid_h=16,              # Token grid height","+        grid_w=16,              # Token grid width","+        d_model=512,            # Transformer dimension","         n_layers=8,             # Number of transformer layers","-        n_heads=6,              # Attention heads","+        n_heads=8,              # Attention heads","         n_actions=4,            # Number of Atari actions","         dropout=0.0,","-        cond_dim=384,           # Conditioning dimension","+        cond_dim=512,           # Conditioning dimension","     ):","         super().__init__()"," ","         self.vocab_size = vocab_size","-        self.num_channels = num_channels","-        self.spatial_h = spatial_h","-        self.spatial_w = spatial_w","-        self.n_tokens = spatial_h * spatial_w  # Tokens per frame (pixel-level)","+        self.grid_h = grid_h","+        self.grid_w = grid_w","+        self.n_tokens = grid_h * grid_w  # 256","         self.d_model = d_model","-        self.mask_token_id = vocab_size  # MASK token is vocab_size","+        self.mask_token_id = vocab_size  # MASK token ID"," ","-        # Token embedding: vocab_size + 1 for MASK token, per channel","-        # We'll embed each pixel as 3 channel tokens concatenated","-        self.channel_embeds = nn.ModuleList([","-            nn.Embedding(vocab_size + 1, d_model // num_channels)","-            for _ in range(num_channels)","-        ])","+        # Token embedding: vocab_size + 1 for MASK token","+        self.token_embed = nn.Embedding(vocab_size + 1, d_model)"," ","         # Positional encoding","-        self.pos_enc = LearnedPositionalEncoding2D(d_model, spatial_h, spatial_w)","+        self.pos_enc = LearnedPositionalEncoding2D(d_model, grid_h, grid_w)"," ","         # Action conditioning","         self.action_embed = nn.Sequential("]},{"oldStart":139,"oldLines":7,"newStart":237,"newLines":7,"lines":["             nn.Linear(cond_dim, cond_dim),","         )"," ","-        # Timestep embedding (for masking ratio)","+        # Timestep embedding (for masking ratio / diffusion time)","         self.time_embed = nn.Sequential(","             nn.Linear(1, cond_dim),","             nn.SiLU(),"]},{"oldStart":153,"oldLines":74,"newStart":251,"newLines":60,"lines":["             nn.Linear(cond_dim, cond_dim),","