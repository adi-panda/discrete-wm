{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018JXQP3S5jX95UM7D8umeYW","type":"tool_result","content":"1\t\"\"\"\n2\tDiscrete Diffusion World Model for Atari.\n3\t\n4\tUses masked discrete diffusion (MDLM-style):\n5\t- Forward process: randomly mask tokens with [MASK]\n6\t- Model predicts original token IDs for masked positions\n7\t- Inference: start from all-masked, iteratively unmask\n8\t\"\"\"\n9\t\n10\timport math\n11\timport torch\n12\timport torch.nn as nn\n13\timport torch.nn.functional as F\n14\tfrom einops import rearrange\n15\t\n16\t\n17\t# --- Positional Encoding ---\n18\t\n19\tclass LearnedPositionalEncoding2D(nn.Module):\n20\t    \"\"\"Learned 2D positional encoding for spatial token grids.\"\"\"\n21\t    def __init__(self, d_model, max_h=64, max_w=64):\n22\t        super().__init__()\n23\t        self.row_embed = nn.Embedding(max_h, d_model // 2)\n24\t        self.col_embed = nn.Embedding(max_w, d_model // 2)\n25\t\n26\t    def forward(self, h, w, device):\n27\t        rows = torch.arange(h, device=device)\n28\t        cols = torch.arange(w, device=device)\n29\t        row_emb = self.row_embed(rows).unsqueeze(1).expand(-1, w, -1)  # [H, W, D/2]\n30\t        col_emb = self.col_embed(cols).unsqueeze(0).expand(h, -1, -1)  # [H, W, D/2]\n31\t        pos = torch.cat([row_emb, col_emb], dim=-1)  # [H, W, D]\n32\t        return pos.reshape(h * w, -1)  # [H*W, D]\n33\t\n34\t\n35\t# --- AdaLN (Adaptive Layer Norm, DiT-style) ---\n36\t\n37\tclass AdaLN(nn.Module):\n38\t    \"\"\"Adaptive Layer Normalization conditioned on external signal.\"\"\"\n39\t    def __init__(self, d_model, cond_dim):\n40\t        super().__init__()\n41\t        self.norm = nn.LayerNorm(d_model, elementwise_affine=False)\n42\t        self.proj = nn.Linear(cond_dim, d_model * 2)\n43\t\n44\t    def forward(self, x, cond):\n45\t        # cond: [B, cond_dim]\n46\t        scale_shift = self.proj(cond).unsqueeze(1)  # [B, 1, 2*D]\n47\t        scale, shift = scale_shift.chunk(2, dim=-1)\n48\t        return self.norm(x) * (1 + scale) + shift\n49\t\n50\t\n51\t# --- Transformer Block with AdaLN ---\n52\t\n53\tclass TransformerBlock(nn.Module):\n54\t    def __init__(self, d_model, n_heads, cond_dim, dropout=0.0, use_cross_attn=True):\n55\t        super().__init__()\n56\t        self.adaln1 = AdaLN(d_model, cond_dim)\n57\t        self.attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n58\t\n59\t        self.use_cross_attn = use_cross_attn\n60\t        if use_cross_attn:\n61\t            self.adaln_cross = AdaLN(d_model, cond_dim)\n62\t            self.cross_attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n63\t\n64\t        self.adaln2 = AdaLN(d_model, cond_dim)\n65\t        self.ffn = nn.Sequential(\n66\t            nn.Linear(d_model, d_model * 4),\n67\t            nn.GELU(),\n68\t            nn.Dropout(dropout),\n69\t            nn.Linear(d_model * 4, d_model),\n70\t            nn.Dropout(dropout),\n71\t        )\n72\t\n73\t    def forward(self, x, cond, context=None):\n74\t        # Self-attention with AdaLN\n75\t        h = self.adaln1(x, cond)\n76\t        h, _ = self.attn(h, h, h)\n77\t        x = x + h\n78\t\n79\t        # Cross-attention to previous frame context\n80\t        if self.use_cross_attn and context is not None:\n81\t            h = self.adaln_cross(x, cond)\n82\t            h, _ = self.cross_attn(h, context, context)\n83\t            x = x + h\n84\t\n85\t        # FFN with AdaLN\n86\t        h = self.adaln2(x, cond)\n87\t        h = self.ffn(h)\n88\t        x = x + h\n89\t\n90\t        return x\n91\t\n92\t\n93\t# --- Main Model ---\n94\t\n95\tclass DiscreteWorldModel(nn.Module):\n96\t    \"\"\"\n97\t    Masked discrete diffusion model for Atari frame prediction.\n98\t\n99\t    Given previous frame tokens + action, predicts next frame tokens.\n100\t    Uses cosine masking schedule and iterative unmasking for generation.\n101\t    \"\"\"\n102\t    def __init__(\n103\t        self,\n104\t        vocab_size=64,          # Number of discrete bins per channel\n105\t        num_channels=3,         # RGB\n106\t        spatial_h=64,           # Frame height\n107\t        spatial_w=64,           # Frame width\n108\t        d_model=384,            # Transformer dimension\n109\t        n_layers=8,             # Number of transformer layers\n110\t        n_heads=6,              # Attention heads\n111\t        n_actions=4,            # Number of Atari actions\n112\t        dropout=0.0,\n113\t        cond_dim=384,           # Conditioning dimension\n114\t    ):\n115\t        super().__init__()\n116\t\n117\t        self.vocab_size = vocab_size\n118\t        self.num_channels = num_channels\n119\t        self.spatial_h = spatial_h\n120\t        self.spatial_w = spatial_w\n121\t        self.n_tokens = spatial_h * spatial_w  # Tokens per frame (pixel-level)\n122\t        self.d_model = d_model\n123\t        self.mask_token_id = vocab_size  # MASK token is vocab_size\n124\t\n125\t        # Token embedding: vocab_size + 1 for MASK token, per channel\n126\t        # We'll embed each pixel as 3 channel tokens concatenated\n127\t        self.channel_embeds = nn.ModuleList([\n128\t            nn.Embedding(vocab_size + 1, d_model // num_channels)\n129\t            for _ in range(num_channels)\n130\t        ])\n131\t\n132\t        # Positional encoding\n133\t        self.pos_enc = LearnedPositionalEncoding2D(d_model, spatial_h, spatial_w)\n134\t\n135\t        # Action conditioning\n136\t        self.action_embed = nn.Sequential(\n137\t            nn.Embedding(n_actions, cond_dim),\n138\t            nn.SiLU(),\n139\t            nn.Linear(cond_dim, cond_dim),\n140\t        )\n141\t\n142\t        # Timestep embedding (for masking ratio)\n143\t        self.time_embed = nn.Sequential(\n144\t            nn.Linear(1, cond_dim),\n145\t            nn.SiLU(),\n146\t            nn.Linear(cond_dim, cond_dim),\n147\t        )\n148\t\n149\t        # Condition projection\n150\t        self.cond_proj = nn.Sequential(\n151\t            nn.Linear(cond_dim, cond_dim),\n152\t            nn.SiLU(),\n153\t            nn.Linear(cond_dim, cond_dim),\n154\t        )\n155\t\n156\t        # Previous frame encoder (lightweight)\n157\t        self.prev_frame_proj = nn.Linear(d_model, d_model)\n158\t\n159\t        # Transformer layers\n160\t        self.layers = nn.ModuleList([\n161\t            TransformerBlock(d_model, n_heads, cond_dim, dropout, use_cross_attn=True)\n162\t            for _ in range(n_layers)\n163\t        ])\n164\t\n165\t        # Output heads - one per channel\n166\t        self.output_norm = nn.LayerNorm(d_model)\n167\t        self.output_heads = nn.ModuleList([\n168\t            nn.Linear(d_model, vocab_size)\n169\t            for _ in range(num_channels)\n170\t        ])\n171\t\n172\t    def embed_tokens(self, tokens):\n173\t        \"\"\"\n174\t        Embed pixel tokens.\n175\t        tokens: [B, H*W, C] - discrete token ids per channel\n176\t        Returns: [B, H*W, D]\n177\t        \"\"\"\n178\t        channel_embs = []\n179\t        for c in range(self.num_channels):\n180\t            channel_embs.append(self.channel_embeds[c](tokens[:, :, c]))\n181\t        return torch.cat(channel_embs, dim=-1)  # [B, H*W, D]\n182\t\n183\t    def forward(self, masked_tokens, prev_tokens, action, mask_ratio):\n184\t        \"\"\"\n185\t        Forward pass.\n186\t\n187\t        Args:\n188\t            masked_tokens: [B, H*W, C] - current frame with some tokens masked\n189\t            prev_tokens: [B, H*W, C] - previous frame tokens (unmasked)\n190\t            action: [B] - action taken\n191\t            mask_ratio: [B] or [B, 1] - masking ratio (for timestep conditioning)\n192\t\n193\t        Returns:\n194\t            logits: list of [B, H*W, vocab_size] per channel\n195\t        \"\"\"\n196\t        B = masked_tokens.shape[0]\n197\t        device = masked_tokens.device\n198\t\n199\t        # Embed tokens\n200\t        x = self.embed_tokens(masked_tokens)  # [B, N, D]\n201\t\n202\t        # Add positional encoding\n203\t        pos = self.pos_enc(self.spatial_h, self.spatial_w, device)  # [N, D]\n204\t        x = x + pos.unsqueeze(0)\n205\t\n206\t        # Embed previous frame as context\n207\t        context = self.embed_tokens(prev_tokens)  # [B, N, D]\n208\t        context = self.prev_frame_proj(context + pos.unsqueeze(0))\n209\t\n210\t        # Build conditioning signal\n211\t        act_emb = self.action_embed(action)  # [B, cond_dim]\n212\t        if mask_ratio.dim() == 1:\n213\t            mask_ratio = mask_ratio.unsqueeze(-1)\n214\t        time_emb = self.time_embed(mask_ratio.float())  # [B, cond_dim]\n215\t        cond = self.cond_proj(act_emb + time_emb)  # [B, cond_dim]\n216\t\n217\t        # Transformer layers\n218\t        for layer in self.layers:\n219\t            x = layer(x, cond, context)\n220\t\n221\t        # Output\n222\t        x = self.output_norm(x)\n223\t        logits = [head(x) for head in self.output_heads]  # list of [B, N, vocab_size]\n224\t\n225\t        return logits\n226\t\n227\t    @torch.no_grad()\n228\t    def generate(self, prev_tokens, action, num_steps=8, temperature=1.0, device='cuda'):\n229\t        \"\"\"\n230\t        Generate next frame via iterative unmasking.\n231\t\n232\t        Args:\n233\t            prev_tokens: [B, H*W, C] - previous frame tokens\n234\t            action: [B] - action taken\n235\t            num_steps: Number of unmasking steps\n236\t            temperature: Sampling temperature\n237\t\n238\t        Returns:\n239\t            tokens: [B, H*W, C] - generated frame tokens\n240\t        \"\"\"\n241\t        B, N, C = prev_tokens.shape\n242\t\n243\t        # Start fully masked\n244\t        tokens = torch.full((B, N, C), self.mask_token_id, device=device, dtype=torch.long)\n245\t        # Track which positions are still masked (per pixel, all channels masked together)\n246\t        is_masked = torch.ones(B, N, dtype=torch.bool, device=device)\n247\t\n248\t        for step in range(num_steps):\n249\t            # Current mask ratio (decreasing from ~1 to ~0)\n250\t            ratio = 1.0 - (step + 1) / num_steps\n251\t            mask_ratio_tensor = torch.full((B,), ratio, device=device)\n252\t\n253\t            # Get predictions\n254\t            logits = self.forward(tokens, prev_tokens, action, mask_ratio_tensor)\n255\t\n256\t            # For each channel, compute confidence\n257\t            all_probs = []\n258\t            all_sampled = []\n259\t            for c in range(C):\n260\t                probs_c = F.softmax(logits[c] / temperature, dim=-1)  # [B, N, V]\n261\t                sampled_c = torch.multinomial(probs_c.view(-1, self.vocab_size), 1).view(B, N)\n262\t                confidence_c = probs_c.max(dim=-1).values  # [B, N]\n263\t                all_probs.append(confidence_c)\n264\t                all_sampled.append(sampled_c)\n265\t\n266\t            # Average confidence across channels\n267\t            avg_confidence = torch.stack(all_probs, dim=-1).mean(dim=-1)  # [B, N]\n268\t\n269\t            # Only consider currently masked positions\n270\t            avg_confidence[~is_masked] = -float('inf')\n271\t\n272\t            if step < num_steps - 1:\n273\t                # Number of tokens to unmask this step\n274\t                n_masked = is_masked.sum(dim=1)  # [B]\n275\t                n_to_unmask = torch.clamp(\n276\t                    (n_masked.float() - N * ratio).long(),\n277\t                    min=1\n278\t                )\n279\t\n280\t                # Unmask top-confidence positions per batch\n281\t                for b in range(B):\n282\t                    if n_to_unmask[b] <= 0:\n283\t                        continue\n284\t                    masked_indices = is_masked[b].nonzero(as_tuple=True)[0]\n285\t                    if len(masked_indices) == 0:\n286\t                        continue\n287\t                    conf_masked = avg_confidence[b, masked_indices]\n288\t                    n_unmask = min(n_to_unmask[b].item(), len(masked_indices))\n289\t                    _, top_indices = conf_masked.topk(n_unmask)\n290\t                    unmask_positions = masked_indices[top_indices]\n291\t\n292\t                    for c in range(C):\n293\t                        tokens[b, unmask_positions, c] = all_sampled[c][b, unmask_positions]\n294\t                    is_masked[b, unmask_positions] = False\n295\t            else:\n296\t                # Last step: unmask everything remaining\n297\t                for c in range(C):\n298\t                    tokens[:, :, c] = torch.where(is_masked, all_sampled[c], tokens[:, :, c])\n299\t                is_masked.fill_(False)\n300\t\n301\t        return tokens\n302\t\n303\t\n304\tdef tokenize_frames(frames, num_bins=64):\n305\t    \"\"\"\n306\t    Convert uint8 frames [B, H, W, C] or [B, C, H, W] to discrete tokens.\n307\t\n308\t    Args:\n309\t        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n310\t        num_bins: Number of discrete bins\n311\t\n312\t    Returns:\n313\t        tokens: [B, H*W, C] in range [0, num_bins-1]\n314\t    \"\"\"\n315\t    if frames.dtype == torch.uint8:\n316\t        frames = frames.float()\n317\t\n318\t    # If channels-first, convert to channels-last\n319\t    if frames.dim() == 4 and frames.shape[1] == 3:\n320\t        frames = frames.permute(0, 2, 3, 1)\n321\t\n322\t    B, H, W, C = frames.shape\n323\t    # Quantize to bins\n324\t    tokens = (frames / 256.0 * num_bins).long().clamp(0, num_bins - 1)\n325\t    tokens = tokens.reshape(B, H * W, C)\n326\t    return tokens\n327\t\n328\t\n329\tdef detokenize_frames(tokens, num_bins=64, h=64, w=64):\n330\t    \"\"\"\n331\t    Convert discrete tokens back to uint8 frames.\n332\t\n333\t    Args:\n334\t        tokens: [B, H*W, C] in range [0, num_bins-1]\n335\t        num_bins: Number of discrete bins\n336\t\n337\t    Returns:\n338\t        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n339\t    \"\"\"\n340\t    # Map bin centers back to pixel values\n341\t    frames = ((tokens.float() + 0.5) / num_bins * 256.0).clamp(0, 255).byte()\n342\t    B = frames.shape[0]\n343\t    frames = frames.reshape(B, h, w, -1)\n344\t    return frames\n345\t"}]},"parent_tool_use_id":null,"session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"bb479e78-8728-4f5c-a38d-4cd3c8f61d22","timestamp":"2026-04-05T08:35:16.662Z","tool_use_result":{"type":"text","file":{"filePath":"/root/research/discrete_wm/models/discrete_diffusion.py","content":"\"\"\"\nDiscrete Diffusion World Model for Atari.\n\nUses masked discrete diffusion (MDLM-style):\n- Forward process: randomly mask tokens with [MASK]\n- Model predicts original token IDs for masked positions\n- Inference: start from all-masked, iteratively unmask\n\"\"\"\n\nimport math\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom einops import rearrange\n\n\n# --- Positional Encoding ---\n\nclass LearnedPositionalEncoding2D(nn.Module):\n    \"\"\"Learned 2D positional encoding for spatial token grids.\"\"\"\n    def __init__(self, d_model, max_h=64, max_w=64):\n        super().__init__()\n        self.row_embed = nn.Embedding(max_h, d_model // 2)\n        self.col_embed = nn.Embedding(max_w, d_model // 2)\n\n    def forward(self, h, w, device):\n        rows = torch.arange(h, device=device)\n        cols = torch.arange(w, device=device)\n        row_emb = self.row_embed(rows).unsqueeze(1).expand(-1, w, -1)  # [H, W, D/2]\n        col_emb = self.col_embed(cols).unsqueeze(0).expand(h, -1, -1)  # [H, W, D/2]\n        pos = torch.cat([row_emb, col_emb], dim=-1)  # [H, W, D]\n        return pos.reshape(h * w, -1)  # [H*W, D]\n\n\n# --- AdaLN (Adaptive Layer Norm, DiT-style) ---\n\nclass AdaLN(nn.Module):\n    \"\"\"Adaptive Layer Normalization conditioned on external signal.\"\"\"\n    def __init__(self, d_model, cond_dim):\n        super().__init__()\n        self.norm = nn.LayerNorm(d_model, elementwise_affine=False)\n        self.proj = nn.Linear(cond_dim, d_model * 2)\n\n    def forward(self, x, cond):\n        # cond: [B, cond_dim]\n        scale_shift = self.proj(cond).unsqueeze(1)  # [B, 1, 2*D]\n        scale, shift = scale_shift.chunk(2, dim=-1)\n        return self.norm(x) * (1 + scale) + shift\n\n\n# --- Transformer Block with AdaLN ---\n\nclass TransformerBlock(nn.Module):\n    def __init__(self, d_model, n_heads, cond_dim, dropout=0.0, use_cross_attn=True):\n        super().__init__()\n        self.adaln1 = AdaLN(d_model, cond_dim)\n        self.attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n\n        self.use_cross_attn = use_cross_attn\n        if use_cross_attn:\n            self.adaln_cross = AdaLN(d_model, cond_dim)\n            self.cross_attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n\n        self.adaln2 = AdaLN(d_model, cond_dim)\n        self.ffn = nn.Sequential(\n            nn.Linear(d_model, d_model * 4),\n            nn.GELU(),\n            nn.Dropout(dropout),\n            nn.Linear(d_model * 4, d_model),\n            nn.Dropout(dropout),\n        )\n\n    def forward(self, x, cond, context=None):\n        # Self-attention with AdaLN\n        h = self.adaln1(x, cond)\n        h, _ = self.attn(h, h, h)\n        x = x + h\n\n        # Cross-attention to previous frame context\n        if self.use_cross_attn and context is not None:\n            h = self.adaln_cross(x, cond)\n            h, _ = self.cross_attn(h, context, context)\n            x = x + h\n\n        # FFN with AdaLN\n        h = self.adaln2(x, cond)\n        h = self.ffn(h)\n        x = x + h\n\n        return x\n\n\n# --- Main Model ---\n\nclass DiscreteWorldModel(nn.Module):\n    \"\"\"\n    Masked discrete diffusion model for Atari frame prediction.\n\n    Given previous frame tokens + action, predicts next frame tokens.\n    Uses cosine masking schedule and iterative unmasking for generation.\n    \"\"\"\n    def __init__(\n        self,\n        vocab_size=64,          # Number of discrete bins per channel\n        num_channels=3,         # RGB\n        spatial_h=64,           # Frame height\n        spatial_w=64,           # Frame width\n        d_model=384,            # Transformer dimension\n        n_layers=8,             # Number of transformer layers\n        n_heads=6,              # Attention heads\n        n_actions=4,            # Number of Atari actions\n        dropout=0.0,\n        cond_dim=384,           # Conditioning dimension\n    ):\n        super().__init__()\n\n        self.vocab_size = vocab_size\n        self.num_channels = num_channels\n        self.spatial_h = spatial_h\n        self.spatial_w = spatial_w\n        self.n_tokens = spatial_h * spatial_w  # Tokens per frame (pixel-level)\n        self.d_model = d_model\n        self.mask_token_id = vocab_size  # MASK token is vocab_size\n\n        # Token embedding: vocab_size + 1 for MASK token, per channel\n        # We'll embed each pixel as 3 channel tokens concatenated\n        self.channel_embeds = nn.ModuleList([\n            nn.Embedding(vocab_size + 1, d_model // num_channels)\n            for _ in range(num_channels)\n        ])\n\n        # Positional encoding\n        self.pos_enc = LearnedPositionalEncoding2D(d_model, spatial_h, spatial_w)\n\n        # Action conditioning\n        self.action_embed = nn.Sequential(\n            nn.Embedding(n_actions, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Timestep embedding (for masking ratio)\n        self.time_embed = nn.Sequential(\n            nn.Linear(1, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Condition projection\n        self.cond_proj = nn.Sequential(\n            nn.Linear(cond_dim, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Previous frame encoder (lightweight)\n        self.prev_frame_proj = nn.Linear(d_model, d_model)\n\n        # Transformer layers\n        self.layers = nn.ModuleList([\n            TransformerBlock(d_model, n_heads, cond_dim, dropout, use_cross_attn=True)\n            for _ in range(n_layers)\n        ])\n\n        # Output heads - one per channel\n        self.output_norm = nn.LayerNorm(d_model)\n        self.output_heads = nn.ModuleList([\n            nn.Linear(d_model, vocab_size)\n            for _ in range(num_channels)\n        ])\n\n    def embed_tokens(self, tokens):\n        \"\"\"\n        Embed pixel tokens.\n        tokens: [B, H*W, C] - discrete token ids per channel\n        Returns: [B, H*W, D]\n        \"\"\"\n        channel_embs = []\n        for c in range(self.num_channels):\n            channel_embs.append(self.channel_embeds[c](tokens[:, :, c]))\n        return torch.cat(channel_embs, dim=-1)  # [B, H*W, D]\n\n    def forward(self, masked_tokens, prev_tokens, action, mask_ratio):\n        \"\"\"\n        Forward pass.\n\n        Args:\n            masked_tokens: [B, H*W, C] - current frame with some tokens masked\n            prev_tokens: [B, H*W, C] - previous frame tokens (unmasked)\n            action: [B] - action taken\n            mask_ratio: [B] or [B, 1] - masking ratio (for timestep conditioning)\n\n        Returns:\n            logits: list of [B, H*W, vocab_size] per channel\n        \"\"\"\n        B = masked_tokens.shape[0]\n        device = masked_tokens.device\n\n        # Embed tokens\n        x = self.embed_tokens(masked_tokens)  # [B, N, D]\n\n        # Add positional encoding\n        pos = self.pos_enc(self.spatial_h, self.spatial_w, device)  # [N, D]\n        x = x + pos.unsqueeze(0)\n\n        # Embed previous frame as context\n        context = self.embed_tokens(prev_tokens)  # [B, N, D]\n        context = self.prev_frame_proj(context + pos.unsqueeze(0))\n\n        # Build conditioning signal\n        act_emb = self.action_embed(action)  # [B, cond_dim]\n        if mask_ratio.dim() == 1:\n            mask_ratio = mask_ratio.unsqueeze(-1)\n        time_emb = self.time_embed(mask_ratio.float())  # [B, cond_dim]\n        cond = self.cond_proj(act_emb + time_emb)  # [B, cond_dim]\n\n        # Transformer layers\n        for layer in self.layers:\n            x = layer(x, cond, context)\n\n        # Output\n        x = self.output_norm(x)\n        logits = [head(x) for head in self.output_heads]  # list of [B, N, vocab_size]\n\n        return logits\n\n    @torch.no_grad()\n    def generate(self, prev_tokens, action, num_steps=8, temperature=1.0, device='cuda'):\n        \"\"\"\n        Generate next frame via iterative unmasking.\n\n        Args:\n            prev_tokens: [B, H*W, C] - previous frame tokens\n            action: [B] - action taken\n            num_steps: Number of unmasking steps\n            temperature: Sampling temperature\n\n        Returns:\n            tokens: [B, H*W, C] - generated frame tokens\n        \"\"\"\n        B, N, C = prev_tokens.shape\n\n        # Start fully masked\n        tokens = torch.full((B, N, C), self.mask_token_id, device=device, dtype=torch.long)\n        # Track which positions are still masked (per pixel, all channels masked together)\n        is_masked = torch.ones(B, N, dtype=torch.bool, device=device)\n\n        for step in range(num_steps):\n            # Current mask ratio (decreasing from ~1 to ~0)\n            ratio = 1.0 - (step + 1) / num_steps\n            mask_ratio_tensor = torch.full((B,), ratio, device=device)\n\n            # Get predictions\n            logits = self.forward(tokens, prev_tokens, action, mask_ratio_tensor)\n\n            # For each channel, compute confidence\n            all_probs = []\n            all_sampled = []\n            for c in range(C):\n                probs_c = F.softmax(logits[c] / temperature, dim=-1)  # [B, N, V]\n                sampled_c = torch.multinomial(probs_c.view(-1, self.vocab_size), 1).view(B, N)\n                confidence_c = probs_c.max(dim=-1).values  # [B, N]\n                all_probs.append(confidence_c)\n                all_sampled.append(sampled_c)\n\n            # Average confidence across channels\n            avg_confidence = torch.stack(all_probs, dim=-1).mean(dim=-1)  # [B, N]\n\n            # Only consider currently masked positions\n            avg_confidence[~is_masked] = -float('inf')\n\n            if step < num_steps - 1:\n                # Number of tokens to unmask this step\n                n_masked = is_masked.sum(dim=1)  # [B]\n                n_to_unmask = torch.clamp(\n                    (n_masked.float() - N * ratio).long(),\n                    min=1\n                )\n\n                # Unmask top-confidence positions per batch\n                for b in range(B):\n                    if n_to_unmask[b] <= 0:\n                        continue\n                    masked_indices = is_masked[b].nonzero(as_tuple=True)[0]\n                    if len(masked_indices) == 0:\n                        continue\n                    conf_masked = avg_confidence[b, masked_indices]\n                    n_unmask = min(n_to_unmask[b].item(), len(masked_indices))\n                    _, top_indices = conf_masked.topk(n_unmask)\n                    unmask_positions = masked_indices[top_indices]\n\n                    for c in range(C):\n                        tokens[b, unmask_positions, c] = all_sampled[c][b, unmask_positions]\n                    is_masked[b, unmask_positions] = False\n            else:\n                # Last step: unmask everything remaining\n                for c in range(C):\n                    tokens[:, :, c] = torch.where(is_masked, all_sampled[c], tokens[:, :, c])\n                is_masked.fill_(False)\n\n        return tokens\n\n\ndef tokenize_frames(frames, num_bins=64):\n    \"\"\"\n    Convert uint8 frames [B, H, W, C] or [B, C, H, W] to discrete tokens.\n\n    Args:\n        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n        num_bins: Number of discrete bins\n\n    Returns:\n        tokens: [B, H*W, C] in range [0, num_bins-1]\n    \"\"\"\n    if frames.dtype == torch.uint8:\n        frames = frames.float()\n\n    # If channels-first, convert to channels-last\n    if frames.dim() == 4 and frames.shape[1] == 3:\n        frames = frames.permute(0, 2, 3, 1)\n\n    B, H, W, C = frames.shape\n    # Quantize to bins\n    tokens = (frames / 256.0 * num_bins).long().clamp(0, num_bins - 1)\n    tokens = tokens.reshape(B, H * W, C)\n    return tokens\n\n\ndef detokenize_frames(tokens, num_bins=64, h=64, w=64):\n    \"\"\"\n    Convert discrete tokens back to uint8 frames.\n\n    Args:\n        tokens: [B, H*W, C] in range [0, num_bins-1]\n        num_bins: Number of discrete bins\n\n    Returns:\n        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n    \"\"\"\n    # Map bin centers back to pixel values\n    frames = ((tokens.float() + 0.5) / num_bins * 256.0).clamp(0, 255).byte()\n    B = frames.shape[0]\n    frames = frames.reshape(B, h, w, -1)\n    return frames\n","numLines":345,"startLine":1,"totalLines":345}}}
