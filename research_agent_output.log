{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014UzYfAPpU4nx7QKbGGWLgD","type":"tool_result","content":"27\t    Decoder: codebook embedding → linear projection → 4x4x3 patch\n28\t    \"\"\"\n29\t    def __init__(self, patch_size=4, num_channels=3, vocab_size=512, embed_dim=256):\n30\t        super().__init__()\n31\t        self.patch_size = patch_size\n32\t        self.num_channels = num_channels\n33\t        self.vocab_size = vocab_size\n34\t        self.embed_dim = embed_dim\n35\t        self.patch_dim = patch_size * patch_size * num_channels  # 48\n36\t\n37\t        # Encoder\n38\t        self.encoder = nn.Sequential(\n39\t            nn.Linear(self.patch_dim, embed_dim),\n40\t            nn.GELU(),\n41\t            nn.Linear(embed_dim, embed_dim),\n42\t        )\n43\t\n44\t        # Codebook\n45\t        self.codebook = nn.Embedding(vocab_size, embed_dim)\n46\t        # Initialize codebook uniformly\n47\t        nn.init.uniform_(self.codebook.weight, -1.0 / vocab_size, 1.0 / vocab_size)\n48\t\n49\t        # Decoder\n50\t        self.decoder = nn.Sequential(\n51\t            nn.Linear(embed_dim, embed_dim),\n52\t            nn.GELU(),\n53\t            nn.Linear(embed_dim, self.patch_dim),\n54\t        )\n55\t\n56\t        # EMA update for codebook\n57\t        self.register_buffer('ema_count', torch.zeros(vocab_size))\n58\t        self.register_buffer('ema_weight', self.codebook.weight.data.clone())\n59\t        self.decay = 0.99\n60\t\n61\t    def encode(self, frames):\n62\t        \"\"\"\n63\t        frames: [B, H, W, C] uint8 or float [0, 255]\n64\t        Returns: tokens [B, N], embeddings [B, N, D]\n65\t        \"\"\"\n66\t        if frames.dtype == torch.uint8:\n67\t            frames = frames.float()\n68\t        frames = frames / 255.0 * 2.0 - 1.0  # Normalize to [-1, 1]\n69\t\n70\t        B, H, W, C = frames.shape\n71\t        ps = self.patch_size\n72\t\n73\t        # Extract patches: [B, H/ps, W/ps, ps*ps*C]\n74\t        patches = rearrange(frames, 'b (h p1) (w p2) c -> b (h w) (p1 p2 c)',\n75\t                           p1=ps, p2=ps)  # [B, N, 48]\n76\t\n77\t        # Encode\n78\t        z_e = self.encoder(patches)  # [B, N, D]\n79\t\n80\t        # Quantize: find nearest codebook entry\n81\t        # z_e: [B, N, D], codebook: [V, D]\n82\t        dists = torch.cdist(z_e, self.codebook.weight.unsqueeze(0).expand(B, -1, -1))  # [B, N, V]\n83\t        tokens = dists.argmin(dim=-1)  # [B, N]\n84\t\n85\t        # Get quantized embeddings\n86\t        z_q = self.codebook(tokens)  # [B, N, D]\n87\t\n88\t        # Straight-through estimator\n89\t        z_q_st = z_e + (z_q - z_e).detach()\n90\t\n91\t        return tokens, z_q_st, z_e, z_q\n92\t\n93\t    def decode(self, z_q):\n94\t        \"\"\"\n95\t        z_q: [B, N, D]\n96\t        Returns: frames [B, H, W, C] in [-1, 1]\n97\t        \"\"\"\n98\t        patches = self.decoder(z_q)  # [B, N, patch_dim]\n99\t        h = w = int(math.sqrt(patches.shape[1]))\n100\t        ps = self.patch_size\n101\t        frames = rearrange(patches, 'b (h w) (p1 p2 c) -> b (h p1) (w p2) c',\n102\t                          h=h, w=w, p1=ps, p2=ps)\n103\t        return frames\n104\t\n105\t    def decode_tokens(self, tokens):\n106\t        \"\"\"Decode from discrete token IDs.\"\"\""}]},"parent_tool_use_id":null,"session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"a81a8475-53de-4e3a-a5d7-36e269feeab6","timestamp":"2026-04-05T08:40:02.644Z","tool_use_result":{"type":"text","file":{"filePath":"/root/research/discrete_wm/models/discrete_diffusion.py","content":"    Decoder: codebook embedding → linear projection → 4x4x3 patch\n    \"\"\"\n    def __init__(self, patch_size=4, num_channels=3, vocab_size=512, embed_dim=256):\n        super().__init__()\n        self.patch_size = patch_size\n        self.num_channels = num_channels\n        self.vocab_size = vocab_size\n        self.embed_dim = embed_dim\n        self.patch_dim = patch_size * patch_size * num_channels  # 48\n\n        # Encoder\n        self.encoder = nn.Sequential(\n            nn.Linear(self.patch_dim, embed_dim),\n            nn.GELU(),\n            nn.Linear(embed_dim, embed_dim),\n        )\n\n        # Codebook\n        self.codebook = nn.Embedding(vocab_size, embed_dim)\n        # Initialize codebook uniformly\n        nn.init.uniform_(self.codebook.weight, -1.0 / vocab_size, 1.0 / vocab_size)\n\n        # Decoder\n        self.decoder = nn.Sequential(\n            nn.Linear(embed_dim, embed_dim),\n            nn.GELU(),\n            nn.Linear(embed_dim, self.patch_dim),\n        )\n\n        # EMA update for codebook\n        self.register_buffer('ema_count', torch.zeros(vocab_size))\n        self.register_buffer('ema_weight', self.codebook.weight.data.clone())\n        self.decay = 0.99\n\n    def encode(self, frames):\n        \"\"\"\n        frames: [B, H, W, C] uint8 or float [0, 255]\n        Returns: tokens [B, N], embeddings [B, N, D]\n        \"\"\"\n        if frames.dtype == torch.uint8:\n            frames = frames.float()\n        frames = frames / 255.0 * 2.0 - 1.0  # Normalize to [-1, 1]\n\n        B, H, W, C = frames.shape\n        ps = self.patch_size\n\n        # Extract patches: [B, H/ps, W/ps, ps*ps*C]\n        patches = rearrange(frames, 'b (h p1) (w p2) c -> b (h w) (p1 p2 c)',\n                           p1=ps, p2=ps)  # [B, N, 48]\n\n        # Encode\n        z_e = self.encoder(patches)  # [B, N, D]\n\n        # Quantize: find nearest codebook entry\n        # z_e: [B, N, D], codebook: [V, D]\n        dists = torch.cdist(z_e, self.codebook.weight.unsqueeze(0).expand(B, -1, -1))  # [B, N, V]\n        tokens = dists.argmin(dim=-1)  # [B, N]\n\n        # Get quantized embeddings\n        z_q = self.codebook(tokens)  # [B, N, D]\n\n        # Straight-through estimator\n        z_q_st = z_e + (z_q - z_e).detach()\n\n        return tokens, z_q_st, z_e, z_q\n\n    def decode(self, z_q):\n        \"\"\"\n        z_q: [B, N, D]\n        Returns: frames [B, H, W, C] in [-1, 1]\n        \"\"\"\n        patches = self.decoder(z_q)  # [B, N, patch_dim]\n        h = w = int(math.sqrt(patches.shape[1]))\n        ps = self.patch_size\n        frames = rearrange(patches, 'b (h w) (p1 p2 c) -> b (h p1) (w p2) c',\n                          h=h, w=w, p1=ps, p2=ps)\n        return frames\n\n    def decode_tokens(self, tokens):\n        \"\"\"Decode from discrete token IDs.\"\"\"","numLines":80,"startLine":27,"totalLines":395}}}
