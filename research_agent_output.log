        to_log += self.collect_test()\n249\t\n250\t            if should_test and not self._is_model_free:\n251\t                to_log += self.test_agent()\n252\t\n253\t            # Logging\n254\t            to_log.append({\"duration\": (time.time() - start_time) / 3600})\n255\t            if self._rank == 0:\n256\t                wandb_log(to_log, self.epoch)\n257\t            to_log = []\n258\t\n259\t            # Checkpointing\n260\t            self.save_checkpoint()\n261\t            \n262\t            if dist.is_initialized():\n263\t                dist.barrier()\n264\t\n265\t        # Last collect\n266\t        if self._rank == 0 and not self._is_static_dataset:\n267\t            wandb_log(self.collect_test(final=True), self.epoch)\n268\t\n269\t    def collect_initial_dataset(self) -> Tuple[int, Logs]:\n270\t        print(\"\\nInitial collect\\n\")\n271\t        to_log = []\n272\t        c = self._cfg.collection.train\n273\t        min_steps = c.first_epoch.min\n274\t        steps_per_epoch = c.steps_per_epoch\n275\t        max_steps = c.first_epoch.max\n276\t        threshold_rew = c.first_epoch.threshold_rew\n277\t        assert min_steps % steps_per_epoch == 0\n278\t\n279\t        steps = min_steps\n280\t        while True:\n281\t            to_log += self._train_collector.send(NumToCollect(steps=steps))\n282\t            num_steps = self.train_dataset.num_steps\n283\t            total_minority_rew = sum(sorted(self.train_dataset.counts_rew)[:-1])\n284\t            if total_minority_rew >= threshold_rew:\n285\t                break\n286\t            if (max_steps is not None) and num_steps >= max_steps:\n287\t                print(\"Reached the specified maximum for initial collect\")\n288\t                break\n289\t            print(f\"Minority reward: {total_minority_rew}/{threshold_rew} -> Keep collecting\\n\")\n290\t            steps = steps_per_epoch\n291\t\n292\t        print(\"\\nSummary of initial collect:\")\n293\t        print(f\"Num steps: {n