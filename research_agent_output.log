{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KoWw3Tv3KgFaV4CN6X6EqM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Lnh6qBuTY61BFcg7nPmcWq","name":"Write","input":{"file_path":"/root/research/discrete_wm/train_world_model.py","content":"\"\"\"\nTraining script for the discrete diffusion world model.\n\nUsage:\n    python train_world_model.py --data data/atari_data.npz --steps 200000\n\"\"\"\n\nimport argparse\nimport math\nimport os\nimport time\nimport csv\n\nimport torch\nimport torch.nn.functional as F\nfrom torch.utils.data import DataLoader\nfrom tqdm import tqdm\n\nfrom models.discrete_diffusion import DiscreteWorldModel, tokenize_frames, detokenize_frames\nfrom utils import AtariFramePairDataset, cosine_mask_schedule\n\n\ndef save_sample_images(model, dataset, device, step, save_dir, num_bins, num_samples=8, num_steps=8):\n    \"\"\"Generate and save sample predictions.\"\"\"\n    import imageio\n    import numpy as np\n\n    model.eval()\n    os.makedirs(save_dir, exist_ok=True)\n\n    # Get some test samples\n    indices = list(range(0, min(num_samples * 10, len(dataset)), 10))[:num_samples]\n    prev_tokens_list = []\n    actions_list = []\n    gt_tokens_list = []\n\n    for idx in indices:\n        pt, a, nt = dataset[idx]\n        prev_tokens_list.append(pt)\n        actions_list.append(a)\n        gt_tokens_list.append(nt)\n\n    prev_tokens = torch.stack(prev_tokens_list).to(device)\n    actions = torch.stack(actions_list).to(device)\n    gt_tokens = torch.stack(gt_tokens_list).to(device)\n\n    # Generate predictions\n    with torch.no_grad():\n        pred_tokens = model.generate(prev_tokens, actions, num_steps=num_steps, temperature=0.9, device=device)\n\n    # Detokenize\n    pred_frames = detokenize_frames(pred_tokens, num_bins=num_bins).cpu().numpy()\n    gt_frames = detokenize_frames(gt_tokens, num_bins=num_bins).cpu().numpy()\n    prev_frames = detokenize_frames(prev_tokens, num_bins=num_bins).cpu().numpy()\n\n    # Create comparison grid\n    rows = []\n    for i in range(min(num_samples, len(pred_frames))):\n        # prev | gt_next | predicted_next\n        row = np.concatenate([prev_frames[i], gt_frames[i], pred_frames[i]], axis=1)\n        rows.append(row)\n\n    grid = np.concatenate(rows, axis=0)\n    imageio.imwrite(os.path.join(save_dir, f'samples_step_{step:06d}.png'), grid)\n\n    model.train()\n    return pred_frames, gt_frames\n\n\ndef train(args):\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n    print(f\"Using device: {device}\")\n\n    # Dataset\n    dataset = AtariFramePairDataset(args.data, num_bins=args.num_bins)\n    dataloader = DataLoader(\n        dataset, batch_size=args.batch_size, shuffle=True,\n        num_workers=4, pin_memory=True, drop_last=True,\n        persistent_workers=True,\n    )\n\n    # Model\n    model = DiscreteWorldModel(\n        vocab_size=args.num_bins,\n        num_channels=3,\n        spatial_h=64,\n        spatial_w=64,\n        d_model=args.d_model,\n        n_layers=args.n_layers,\n        n_heads=args.n_heads,\n        n_actions=dataset.num_actions,\n        dropout=args.dropout,\n        cond_dim=args.d_model,\n    ).to(device)\n\n    num_params = sum(p.numel() for p in model.parameters())\n    print(f\"Model parameters: {num_params:,} ({num_params / 1e6:.1f}M)\")\n\n    # Optimizer\n    optimizer = torch.optim.AdamW(\n        model.parameters(), lr=args.lr, weight_decay=args.weight_decay,\n        betas=(0.9, 0.95),\n    )\n\n    # LR schedule: warmup + cosine decay\n    def lr_lambda(step):\n        if step < args.warmup_steps:\n            return step / max(1, args.warmup_steps)\n        progress = (step - args.warmup_steps) / max(1, args.total_steps - args.warmup_steps)\n        return 0.5 * (1.0 + math.cos(math.pi * progress))\n\n    scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)\n\n    # Training state\n    global_step = 0\n    best_loss = float('inf')\n\n    # CSV logging\n    os.makedirs(args.log_dir, exist_ok=True)\n    csv_path = os.path.join(args.log_dir, 'training_log.csv')\n    csv_file = open(csv_path, 'w', newline='')\n    csv_writer = csv.writer(csv_file)\n    csv_writer.writerow(['step', 'loss', 'lr', 'time', 'mask_ratio_mean'])\n\n    # Checkpoint resume\n    if args.resume and os.path.exists(args.resume):\n        ckpt = torch.load(args.resume, map_location=device)\n        model.load_state_dict(ckpt['model'])\n        optimizer.load_state_dict(ckpt['optimizer'])\n        scheduler.load_state_dict(ckpt['scheduler'])\n        global_step = ckpt['step']\n        best_loss = ckpt.get('best_loss', float('inf'))\n        print(f\"Resumed from step {global_step}\")\n\n    # Enable mixed precision\n    scaler = torch.amp.GradScaler('cuda')\n    mask_token_id = args.num_bins  # MASK token\n\n    print(f\"\\nStarting training for {args.total_steps} steps...\")\n    print(f\"Batch size: {args.batch_size}, LR: {args.lr}\")\n    print(f\"Model: {args.n_layers} layers, {args.d_model} dim, {args.n_heads} heads\")\n    print(f\"Vocab: {args.num_bins} bins + 1 MASK token\")\n\n    model.train()\n    data_iter = iter(dataloader)\n    start_time = time.time()\n    running_loss = 0.0\n    log_interval = 100\n\n    pbar = tqdm(range(global_step, args.total_steps), desc=\"Training\")\n\n    for step_idx in pbar:\n        # Get batch\n        try:\n            prev_tokens, actions, next_tokens = next(data_iter)\n        except StopIteration:\n            data_iter = iter(dataloader)\n            prev_tokens, actions, next_tokens = next(data_iter)\n\n        prev_tokens = prev_tokens.to(device)\n        actions = actions.to(device)\n        next_tokens = next_tokens.to(device)\n\n        B, N, C = next_tokens.shape\n\n        # Sample masking ratio from cosine schedule\n        t = torch.rand(B, device=device)\n        mask_ratio = cosine_mask_schedule(t)  # [B]\n\n        # Create pixel-level mask (same mask acr