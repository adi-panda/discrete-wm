[B, H, W, C] in range [0, 255]","-    \"\"\"","-    # Map bin centers back to pixel values","+def detokenize_frames_direct(tokens, num_bins=64, h=64, w=64):","+    \"\"\"Reverse of tokenize_frames_direct.\"\"\"","     frames = ((tokens.float() + 0.5) / num_bins * 256.0).clamp(0, 255).byte()","     B = frames.shape[0]","-    frames = frames.reshape(B, h, w, -1)","-    return frames","+    return frames.reshape(B, h, w, -1)"]}],"originalFile":"\"\"\"\nDiscrete Diffusion World Model for Atari.\n\nUses masked discrete diffusion (MDLM-style):\n- Forward process: randomly mask tokens with [MASK]\n- Model predicts original token IDs for masked positions\n- Inference: start from all-masked, iteratively unmask\n\"\"\"\n\nimport math\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom einops import rearrange\n\n\n# --- Positional Encoding ---\n\nclass LearnedPositionalEncoding2D(nn.Module):\n    \"\"\"Learned 2D positional encoding for spatial token grids.\"\"\"\n    def __init__(self, d_model, max_h=64, max_w=64):\n        super().__init__()\n        self.row_embed = nn.Embedding(max_h, d_model // 2)\n        self.col_embed = nn.Embedding(max_w, d_model // 2)\n\n    def forward(self, h, w, device):\n        rows = torch.arange(h, device=device)\n        cols = torch.arange(w, device=device)\n        row_emb = self.row_embed(rows).unsqueeze(1).expand(-1, w, -1)  # [H, W, D/2]\n        col_emb = self.col_embed(cols).unsqueeze(0).expand(h, -1, -1)  # [H, W, D/2]\n        pos = torch.cat([row_emb, col_emb], dim=-1)  # [H, W, D]\n        return pos.reshape(h * w, -1)  # [H*W, D]\n\n\n# --- AdaLN (Adaptive Layer Norm, DiT-style) ---\n\nclass AdaLN(nn.Module):\n    \"\"\"Adaptive Layer Normalization conditioned on external signal.\"\"\"\n    def __init__(self, d_model, cond_dim):\n        super().__init__()\n        self.norm = nn.LayerNorm(d_model, elementwise_affine=False)\n        self.proj = nn.Linear(cond_dim, d_model * 2)\n\n    def forward(self, x, cond):\n        # cond: [B, cond_dim]\n        scale_shift = self.proj(cond).unsqueeze(1)  # [B, 1, 2*D]\n        scale, shift = scale_shift.chunk(2, dim=-1)\n        return self.norm(x) * (1 + scale) + shift\n\n\n# --- Transformer Block with AdaLN ---\n\nclass TransformerBlock(nn.Module):\n    def __init__(self, d_model, n_heads, cond_dim, dropout=0.0, use_cross_attn=True):\n        super().__init__()\n        self.adaln1 = AdaLN(d_model, cond_dim)\n        self.attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n\n        self.use_cross_attn = use_cross_attn\n        if use_cross_attn:\n            self.adaln_cross = AdaLN(d_model, cond_dim)\n            self.cross_attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)\n\n        self.adaln2 = AdaLN(d_model, cond_dim)\n        self.ffn = nn.Sequential(\n            nn.Linear(d_model, d_model * 4),\n            nn.GELU(),\n            nn.Dropout(dropout),\n            nn.Linear(d_model * 4, d_model),\n            nn.Dropout(dropout),\n        )\n\n    def forward(self, x, cond, context=None):\n        # Self-attention with AdaLN\n        h = self.adaln1(x, cond)\n        h, _ = self.attn(h, h, h)\n        x = x + h\n\n        # Cross-attention to previous frame context\n        if self.use_cross_attn and context is not None:\n            h = self.adaln_cross(x, cond)\n            h, _ = self.cross_attn(h, context, context)\n            x = x + h\n\n        # FFN with AdaLN\n        h = self.adaln2(x, cond)\n        h = self.ffn(h)\n        x = x + h\n\n        return x\n\n\n# --- Main Model ---\n\nclass DiscreteWorldModel(nn.Module):\n    \"\"\"\n    Masked discrete diffusion model for Atari frame prediction.\n\n    Given previous frame tokens + action, predicts next frame tokens.\n    Uses cosine masking schedule and iterative unmasking for generation.\n    \"\"\"\n    def __init__(\n        self,\n        vocab_size=64,          # Number of discrete bins per channel\n        num_channels=3,         # RGB\n        spatial_h=64,           # Frame height\n        spatial_w=64,           # Frame width\n        d_model=384,            # Transformer dimension\n        n_layers=8,             # Number of transformer layers\n        n_heads=6,              # Attention heads\n        n_actions=4,            # Number of Atari actions\n        dropout=0.0,\n        cond_dim=384,           # Conditioning dimension\n    ):\n        super().__init__()\n\n        self.vocab_size = vocab_size\n        self.num_channels = num_channels\n        self.spatial_h = spatial_h\n        self.spatial_w = spatial_w\n        self.n_tokens = spatial_h * spatial_w  # Tokens per frame (pixel-level)\n        self.d_model = d_model\n        self.mask_token_id = vocab_size  # MASK token is vocab_size\n\n        # Token embedding: vocab_size + 1 for MASK token, per channel\n        # We'll embed each pixel as 3 channel tokens concatenated\n        self.channel_embeds = nn.ModuleList([\n            nn.Embedding(vocab_size + 1, d_model // num_channels)\n            for _ in range(num_channels)\n        ])\n\n        # Positional encoding\n        self.pos_enc = LearnedPositionalEncoding2D(d_model, spatial_h, spatial_w)\n\n        # Action conditioning\n        self.action_embed = nn.Sequential(\n            nn.Embedding(n_actions, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Timestep embedding (for masking ratio)\n        self.time_embed = nn.Sequential(\n            nn.Linear(1, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Condition projection\n        self.cond_proj = nn.Sequential(\n            nn.Linear(cond_dim, cond_dim),\n            nn.SiLU(),\n            nn.Linear(cond_dim, cond_dim),\n        )\n\n        # Previous frame encoder (lightweight)\n        self.prev_frame_proj = nn.Linear(d_model, d_model)\n\n        # Transformer layers\n        self.layers = nn.ModuleList([\n            TransformerBlock(d_model, n_heads, cond_dim, dropout, use_cross_attn=True)\n            for _ in range(n_layers)\n        ])\n\n        # Output heads - one per channel\n        self.output_norm = nn.LayerNorm(d_model)\n        self.output_heads = nn.ModuleList([\n            nn.Linear(d_model, vocab_size)\n            for _ in range(num_channels)\n        ])\n\n    def embed_tokens(self, tokens):\n        \"\"\"\n        Embed pixel tokens.\n        tokens: [B, H*W, C] - discrete token ids per channel\n        Returns: [B, H*W, D]\n        \"\"\"\n        channel_embs = []\n        for c in range(self.num_channels):\n            channel_embs.append(self.channel_embeds[c](tokens[:, :, c]))\n        return torch.cat(channel_embs, dim=-1)  # [B, H*W, D]\n\n    def forward(self, masked_tokens, prev_tokens, action, mask_ratio):\n        \"\"\"\n        Forward pass.\n\n        Args:\n            masked_tokens: [B, H*W, C] - current frame with some tokens masked\n            prev_tokens: [B, H*W, C] - previous frame tokens (unmasked)\n            action: [B] - action taken\n            mask_ratio: [B] or [B, 1] - masking ratio (for timestep conditioning)\n\n        Returns:\n            logits: list of [B, H*W, vocab_size] per channel\n        \"\"\"\n        B = masked_tokens.shape[0]\n        device = masked_tokens.device\n\n        # Embed tokens\n        x = self.embed_tokens(masked_tokens)  # [B, N, D]\n\n        # Add positional encoding\n        pos = self.pos_enc(self.spatial_h, self.spatial_w, device)  # [N, D]\n        x = x + pos.unsqueeze(0)\n\n        # Embed previous frame as context\n        context = self.embed_tokens(prev_tokens)  # [B, N, D]\n        context = self.prev_frame_proj(context + pos.unsqueeze(0))\n\n        # Build conditioning signal\n        act_emb = self.action_embed(action)  # [B, cond_dim]\n        if mask_ratio.dim() == 1:\n            mask_ratio = mask_ratio.unsqueeze(-1)\n        time_emb = self.time_embed(mask_ratio.float())  # [B, cond_dim]\n        cond = self.cond_proj(act_emb + time_emb)  # [B, cond_dim]\n\n        # Transformer layers\n        for layer in self.layers:\n            x = layer(x, cond, context)\n\n        # Output\n        x = self.output_norm(x)\n        logits = [head(x) for head in self.output_heads]  # list of [B, N, vocab_size]\n\n        return logits\n\n    @torch.no_grad()\n    def generate(self, prev_tokens, action, num_steps=8, temperature=1.0, device='cuda'):\n        \"\"\"\n        Generate next frame via iterative unmasking.\n\n        Args:\n            prev_tokens: [B, H*W, C] - previous frame tokens\n            action: [B] - action taken\n            num_steps: Number of unmasking steps\n            temperature: Sampling temperature\n\n        Returns:\n            tokens: [B, H*W, C] - generated frame tokens\n        \"\"\"\n        B, N, C = prev_tokens.shape\n\n        # Start fully masked\n        tokens = torch.full((B, N, C), self.mask_token_id, device=device, dtype=torch.long)\n        # Track which positions are still masked (per pixel, all channels masked together)\n        is_masked = torch.ones(B, N, dtype=torch.bool, device=device)\n\n        for step in range(num_steps):\n            # Current mask ratio (decreasing from ~1 to ~0)\n            ratio = 1.0 - (step + 1) / num_steps\n            mask_ratio_tensor = torch.full((B,), ratio, device=device)\n\n            # Get predictions\n            logits = self.forward(tokens, prev_tokens, action, mask_ratio_tensor)\n\n            # For each channel, compute confidence\n            all_probs = []\n            all_sampled = []\n            for c in range(C):\n                probs_c = F.softmax(logits[c] / temperature, dim=-1)  # [B, N, V]\n                sampled_c = torch.multinomial(probs_c.view(-1, self.vocab_size), 1).view(B, N)\n                confidence_c = probs_c.max(dim=-1).values  # [B, N]\n                all_probs.append(confidence_c)\n                all_sampled.append(sampled_c)\n\n            # Average confidence across channels\n            avg_confidence = torch.stack(all_probs, dim=-1).mean(dim=-1)  # [B, N]\n\n            # Only consider currently masked positions\n            avg_confidence[~is_masked] = -float('inf')\n\n            if step < num_steps - 1:\n                # Number of tokens to unmask this step\n                n_masked = is_masked.sum(dim=1)  # [B]\n                n_to_unmask = torch.clamp(\n                    (n_masked.float() - N * ratio).long(),\n                    min=1\n                )\n\n                # Unmask top-confidence positions per batch\n                for b in range(B):\n                    if n_to_unmask[b] <= 0:\n                        continue\n                    masked_indices = is_masked[b].nonzero(as_tuple=True)[0]\n                    if len(masked_indices) == 0:\n                        continue\n                    conf_masked = avg_confidence[b, masked_indices]\n                    n_unmask = min(n_to_unmask[b].item(), len(masked_indices))\n                    _, top_indices = conf_masked.topk(n_unmask)\n                    unmask_positions = masked_indices[top_indices]\n\n                    for c in range(C):\n                        tokens[b, unmask_positions, c] = all_sampled[c][b, unmask_positions]\n                    is_masked[b, unmask_positions] = False\n            else:\n                # Last step: unmask everything remaining\n                for c in range(C):\n                    tokens[:, :, c] = torch.where(is_masked, all_sampled[c], tokens[:, :, c])\n                is_masked.fill_(False)\n\n        return tokens\n\n\ndef tokenize_frames(frames, num_bins=64):\n    \"\"\"\n    Convert uint8 frames [B, H, W, C] or [B, C, H, W] to discrete tokens.\n\n    Args:\n        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n        num_bins: Number of discrete bins\n\n    Returns:\n        tokens: [B, H*W, C] in range [0, num_bins-1]\n    \"\"\"\n    if frames.dtype == torch.uint8:\n        frames = frames.float()\n\n    # If channels-first, convert to channels-last\n    if frames.dim() == 4 and frames.shape[1] == 3:\n        frames = frames.permute(0, 2, 3, 1)\n\n    B, H, W, C = frames.shape\n    # Quantize to bins\n    tokens = (frames / 256.0 * num_bins).long().clamp(0, num_bins - 1)\n    tokens = tokens.reshape(B, H * W, C)\n    return tokens\n\n\ndef detokenize_frames(tokens, num_bins=64, h=64, w=64):\n    \"\"\"\n    Convert discrete tokens back to uint8 frames.\n\n    Args:\n        tokens: [B, H*W, C] in range [0, num_bins-1]\n        num_bins: Number of discrete bins\n\n    Returns:\n        frames: uint8 tensor [B, H, W, C] in range [0, 255]\n    \"\"\"\n    # Map bin centers back to pixel values\n    frames = ((tokens.float() + 0.5) / num_bins * 256.0).clamp(0, 255).byte()\n    B = frames.shape[0]\n    frames = frames.reshape(B, h, w, -1)\n    return frames\n"}}
