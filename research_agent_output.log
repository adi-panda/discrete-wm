{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Ks6aLukEYG6eWh4cy1Q2A","type":"tool_result","content":"1\tfrom dataclasses import dataclass\n2\tfrom typing import Any, Dict, Generator, List, Tuple\n3\t\n4\timport torch\n5\tfrom torch import Tensor\n6\tfrom torch.distributions.categorical import Categorical\n7\tfrom torch.utils.data import DataLoader\n8\t\n9\tfrom coroutines import coroutine\n10\tfrom models.diffusion import Denoiser, DiffusionSampler, DiffusionSamplerConfig\n11\tfrom models.rew_end_model import RewEndModel\n12\t\n13\tResetOutput = Tuple[torch.FloatTensor, Dict[str, Any]]\n14\tStepOutput = Tuple[Tensor, Tensor, Tensor, Tensor, Dict[str, Any]]\n15\tInitialCondition = Tuple[Tensor, Tensor, Tuple[Tensor, Tensor]]\n16\t\n17\t\n18\t@dataclass\n19\tclass WorldModelEnvConfig:\n20\t    horizon: int\n21\t    num_batches_to_preload: int\n22\t    diffusion_sampler: DiffusionSamplerConfig\n23\t\n24\t\n25\tclass WorldModelEnv:\n26\t    def __init__(\n27\t        self,\n28\t        denoiser: Denoiser,\n29\t        rew_end_model: RewEndModel,\n30\t        data_loader: DataLoader,\n31\t        cfg: WorldModelEnvConfig,\n32\t        return_denoising_trajectory: bool = False,\n33\t    ) -> None:\n34\t        self.sampler = DiffusionSampler(denoiser, cfg.diffusion_sampler)\n35\t        self.rew_end_model = rew_end_model\n36\t        self.horizon = cfg.horizon\n37\t        self.return_denoising_trajectory = return_denoising_trajectory\n38\t        self.num_envs = data_loader.batch_sampler.batch_size\n39\t        self.generator_init = self.make_generator_init(data_loader, cfg.num_batches_to_preload)\n40\t\n41\t    @property\n42\t    def device(self) -> torch.device:\n43\t        return self.sampler.denoiser.device\n44\t\n45\t    @torch.no_grad()\n46\t    def reset(self, **kwargs) -> ResetOutput:\n47\t        obs, act, (hx, cx) = self.generator_init.send(self.num_envs)\n48\t        self.obs_buffer = obs\n49\t        self.act_buffer = act\n50\t        self.hx_rew_end = hx\n51\t        self.cx_rew_end = cx\n52\t        self.ep_len = torch.zeros(self.num_envs, dtype=torch.long, device=obs.device)\n53\t        return self.obs_buffer[:, -1], {}\n54\t\n55\t    @torch.no_grad()\n56\t    def reset_dead(self, dead: torch.BoolTensor) -> None:\n57\t        obs, act, (hx, cx) = self.generator_init.send(dead.sum().item())\n58\t        self.obs_buffer[dead] = obs\n59\t        self.act_buffer[dead] = act\n60\t        self.hx_rew_end[:, dead] = hx\n61\t        self.cx_rew_end[:, dead] = cx\n62\t        self.ep_len[dead] = 0\n63\t\n64\t    @torch.no_grad()\n65\t    def step(self, act: torch.LongTensor) -> StepOutput:\n66\t        self.act_buffer[:, -1] = act\n67\t\n68\t        next_obs, denoising_trajectory = self.predict_next_obs()\n69\t        rew, end = self.predict_rew_end(next_obs.unsqueeze(1))\n70\t\n71\t        self.ep_len += 1\n72\t        trunc = (self.ep_len >= self.horizon).long()\n73\t\n74\t        self.obs_buffer = self.obs_buffer.roll(-1, dims=1)\n75\t        self.act_buffer = self.act_buffer.roll(-1, dims=1)\n76\t        self.obs_buffer[:, -1] = next_obs\n77\t\n78\t        dead = torch.logical_or(end, trunc)\n79\t\n80\t        info = {}\n81\t        if self.return_denoising_trajectory:\n82\t            info[\"denoising_trajectory\"] = torch.stack(denoising_trajectory, dim=1)\n83\t\n84\t        if dead.any():\n85\t            self.reset_dead(dead)\n86\t            info[\"final_observation\"] = next_obs[dead]\n87\t            info[\"burnin_obs\"] = self.obs_buffer[dead, :-1]\n88\t\n89\t        return self.obs_buffer[:, -1], rew, end, trunc, info\n90\t\n91\t    @torch.no_grad()\n92\t    def predict_next_obs(self) -> Tuple[Tensor, List[Tensor]]:\n93\t        return self.sampler.sample(self.obs_buffer, self.act_buffer)\n94\t\n95\t    @torch.no_grad()\n96\t    def predict_rew_end(self, next_obs: Tensor) -> Tuple[Tensor, Tensor]:\n97\t        logits_rew, logits_end, (self.hx_rew_end, self.cx_rew_end) = self.rew_end_model.predict_rew_end(\n98\t            self.obs_buffer[:, -1:],\n99\t            self.act_buffer[:, -1:],\n100\t            next_obs,"}]},"parent_tool_use_id":"toolu_01M2MSs1siYH5myM8rgHiPLy","session_id":"6eb3f8f9-70a7-4c62-8ed1-8dd1b9e7b463","uuid":"c1dfc39e-1ca4-4d31-ab09-a5ea8ff21819","timestamp":"2026-04-05T08:29:28.000Z"}
